# Supabase（启用真实跨端登录时填写；不提交真实密钥到仓库；复制为 .env.local 本地使用）
# 纯静态无打包：可在 <script> 中注入
#   window.__LUMINA_ENV__ = { VITE_SUPABASE_URL: "...", VITE_SUPABASE_ANON_KEY: "..." };
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 设为 1 时强制使用本地 demo 认证。Production 与公开预览勿长期开启。
# VITE_LUMINA_AUTH_USE_DEMO=1

# 纯静态、需强制视为「类生产」检测时可设（与部署脚本配合，可选）：
# LUMINA_DEPLOYMENT_TIER=production
# LUMINA_FORCE_PROD=1
