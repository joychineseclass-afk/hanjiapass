  "grammar": [
    {
      "pattern": "吗 — 一般疑问句",
      "pinyin": "ma — yībān yíwènjù",
      "explain": {
        "kr": "평서문 뒤에 「吗」를 붙이면 의문문이 됩니다.",
        "jp": "平叙文の後に「吗」をつけると一般疑問文になります。",
        "en": "Adding 吗 after a statement forms a yes-no question."
      },
      "example": {
        "zh": "你好吗？",
        "pinyin": "Nǐ hǎo ma?",
        "translation": {
          "kr": "잘 지내세요?",
          "jp": "お元気ですか?",
          "en": "How are you?"
        }
      }
    },
    {
      "pattern": "很 + 形容词",
      "pinyin": "hěn + xíngróngcí",
      "explain": {
        "kr": "형용사가 서술어가 될 때 보통 「很」을 함께 사용합니다.",
        "jp": "形容詞が述語になるとき、通常「很」を使います。",
        "en": "Adjectives as predicates usually need 很."
      },
      "example": {
        "zh": "我很好。",
        "pinyin": "Wǒ hěn hǎo.",
        "translation": {
          "kr": "저는 잘 지냅니다.",
          "jp": "元気です。",
          "en": "I'm fine."
        }
      }
    }
  ],
