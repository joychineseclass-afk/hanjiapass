  "grammar": [
    {
      "pattern": "吗（疑问句）",
      "pinyin": "ma (yíwènjù)",
      "explain": {
        "zh": "陈述句后加「吗」构成一般疑问句。结构：是 + 吗",
        "kr": "평서문 뒤에 「吗」를 붙이면 의문문이 됩니다. 구조: 是 + 吗",
        "en": "Adding 吗 after a statement forms a yes-no question. Pattern: 是 + 吗",
        "jp": "平叙文の後に「吗」をつけると一般疑問文になります。構造：是 + 吗"
      },
      "example": {
        "zh": "你是学生吗？",
        "pinyin": "Nǐ shì xuésheng ma?",
        "translation": { "kr": "너는 학생이야?", "jp": "あなたは学生ですか?", "en": "Are you a student?" }
      }
    }
