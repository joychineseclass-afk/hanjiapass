      "lines": [
        { "speaker": "A", "zh": "你喝茶吗？", "pinyin": "Nǐ hē chá ma?", "kr": "차 마셔요?", "text": "你喝茶吗？", "translation": { "kr": "차 마셔요?", "en": "Do you drink tea?", "jp": "お茶を飲みますか？" } },
