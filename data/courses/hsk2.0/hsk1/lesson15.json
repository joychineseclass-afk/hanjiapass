      ]
    },
    {
      "title": { "zh": "会话2", "kr": "회화2", "en": "Session 2", "jp": "会話2" },
      "lines": [
        { "speaker": "A", "zh": "在饭馆。你喝茶吗？", "pinyin": "Zài fànguǎn. Nǐ hē chá ma?", "kr": "식당이에요. 차 마셔요?", "text": "在饭馆。你喝茶吗？", "translation": { "kr": "식당이에요. 차 마셔요?", "en": "At the restaurant. Do you drink tea?", "jp": "レストランです。お茶を飲みますか？" } },
        { "speaker": "B", "zh": "喝。一个杯子。", "pinyin": "Hē. Yī gè bēizi.", "kr": "마셔요. 컵 하나요.", "text": "喝。一个杯子。", "translation": { "kr": "마셔요. 컵 하나요.", "en": "Yes. One cup.", "jp": "飲みます。コップ一つ。" } }
      ]
    },
    {
      "title": { "zh": "会话3", "kr": "회화3", "en": "Session 3", "jp": "会話3" },
      "lines": [
        { "speaker": "A", "zh": "饭馆什么东西好吃？", "pinyin": "Fànguǎn shénme dōngxi hǎo chī?", "kr": "식당에서 뭐가 맛있어요?", "text": "饭馆什么东西好吃？", "translation": { "kr": "식당에서 뭐가 맛있어요?", "en": "What's good at the restaurant?", "jp": "レストランで何がおいしいですか？" } },
        { "speaker": "B", "zh": "米饭好吃。五块。", "pinyin": "Mǐfàn hǎo chī. Wǔ kuài.", "kr": "밥이 맛있어요. 5위안이에요.", "text": "米饭好吃。五块。", "translation": { "kr": "밥이 맛있어요. 5위안이에요.", "en": "Rice is good. Five yuan.", "jp": "ご飯がおいしいです。5元です。" } }
      ]
    }
