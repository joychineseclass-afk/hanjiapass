      "title": { "zh": "会话1", "kr": "회화1", "en": "Session 1", "jp": "会話1" },
      "lines": [
        { "speaker": "A", "text": "你叫什么名字？", "pinyin": "Nǐ jiào shénme míngzi?", "translation": { "kr": "이름이 뭐예요?", "en": "What is your name?", "jp": "お名前は何ですか？" } },
        { "speaker": "B", "text": "我叫小明。", "pinyin": "Wǒ jiào Xiǎomíng.", "translation": { "kr": "저는 샤오밍이에요.", "en": "My name is Xiaoming.", "jp": "私は小明です。" } }
      ]
    },
    {
      "title": { "zh": "会话2", "kr": "회화2", "en": "Session 2", "jp": "会話2" },
      "lines": [
        { "speaker": "A", "text": "我叫小美。", "pinyin": "Wǒ jiào Xiǎoměi.", "translation": { "kr": "저는 샤오메이예요.", "en": "My name is Xiaomei.", "jp": "私は小美です。" } },
        { "speaker": "B", "text": "很高兴认识你。", "pinyin": "Hěn gāoxìng rènshi nǐ.", "translation": { "kr": "만나서 반가워요.", "en": "Nice to meet you.", "jp": "お会いできて嬉しいです。" } }
      ]
    }
  ],
  "dialogueCards": [
    {
      "title": { "zh": "会话1", "kr": "회화1", "en": "Session 1", "jp": "会話1" },
      "lines": [
        { "speaker": "A", "text": "你好！你叫什么名字？", "pinyin": "Nǐ hǎo! Nǐ jiào shénme míngzi?", "translation": { "kr": "안녕하세요! 이름이 뭐예요?", "en": "Hello! What is your name?", "jp": "こんにちは! お名前は何ですか？" } },
        { "speaker": "B", "text": "我叫小明。很高兴认识你。", "pinyin": "Wǒ jiào Xiǎomíng. Hěn gāoxìng rènshi nǐ.", "translation": { "kr": "저는 샤오밍이에요. 만나서 반가워요.", "en": "My name is Xiaoming. Nice to meet you.", "jp": "私は小明です。お会いできて嬉しいです。" } }
      ]
    },
    {
      "title": { "zh": "会话2", "kr": "회화2", "en": "Session 2", "jp": "会話2" },
      "lines": [
        { "speaker": "A", "text": "谢谢你。", "pinyin": "Xièxie nǐ.", "translation": { "kr": "감사해요.", "en": "Thank you.", "jp": "ありがとうございます。" } },
        { "speaker": "B", "text": "不客气。再见！", "pinyin": "Bùkèqi. Zàijiàn!", "translation": { "kr": "천만에요. 안녕히 가세요!", "en": "You're welcome. Goodbye!", "jp": "どういたしまして。さようなら!" } }
      ]
    }
  ],
  "grammar": [
    {
      "title": "叫 + 名字",
      "explanation_zh": "用「叫」来介绍或询问名字。",
      "explanation_kr": "'叫'로 이름을 소개하거나 물을 수 있습니다.",
      "explanation_en": "Use 叫 to introduce or ask for names.",
      "example": {
        "zh": "我叫李明。",
        "pinyin": "Wǒ jiào Lǐ Míng.",
        "kr": "저는 이명이에요.",
        "en": "I'm Li Ming."
      },
      "explain": {
        "jp": "「叫」で名前を紹介したり聞いたりします。",
        "en": "Use 叫 to introduce or ask for names.",
        "kr": "'叫'로 이름을 소개하거나 물을 수 있습니다.",
        "zh": "用「叫」来介绍或询问名字。"
      }
    },
    {
      "title": "什么 — 疑问词",
      "explanation_zh": "「什么」用于询问事物或名字。",
      "explanation_kr": "'什么'은 사물이나 이름을 물을 때 사용합니다.",
      "explanation_en": "什么 is used to ask about things or names.",
      "example": {
        "zh": "你叫什么名字？",
        "pinyin": "Nǐ jiào shénme míngzi?",
        "kr": "이름이 뭐예요?",
        "en": "What's your name?"
      },
      "explain": {
        "jp": "「什么」は物や名前を聞くときに使います。",
        "en": "什么 is used to ask about things or names.",
        "kr": "'什么'은 사물이나 이름을 물을 때 사용합니다.",
        "zh": "「什么」用于询问事物或名字。"
      }
    },
    {
      "title": "A 是 B",
      "explanation_zh": "「是」表示等同关系。",
      "explanation_kr": "'是'는 동일 관계를 나타냅니다.",
      "explanation_en": "是 indicates equality.",
      "example": {
        "zh": "我是学生。",
        "pinyin": "Wǒ shì xuésheng.",
        "kr": "저는 학생이에요.",
        "en": "I am a student."
      },
      "explain": {
        "jp": "「是」は主語と目的語をつなぎ、同等であることを表します。",
        "en": "是 indicates equality.",
        "kr": "'是'는 동일 관계를 나타냅니다.",
        "zh": "「是」表示等同关系。"
      }
    }
  ],
