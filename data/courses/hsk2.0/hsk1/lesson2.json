  "dialogue": [
    {
      "speaker": "A",
      "line": "你好！你叫什么名字？",
      "kr": "안녕하세요! 이름이 뭐예요?",
      "en": "Hello! What's your name?"
    },
    {
      "speaker": "B",
      "line": "我叫小明。你呢？",
      "kr": "저는 소명이에요. 당신은요?",
      "en": "I'm Xiaoming. And you?"
    },
    {
      "speaker": "A",
      "line": "我叫小美。很高兴认识你！",
      "kr": "저는 소미예요. 만나서 반가워요!",
      "en": "I'm Xiaomei. Nice to meet you!"
    },
    {
      "speaker": "B",
      "line": "谢谢！",
      "kr": "감사합니다!",
      "en": "Thanks!"
    },
    {
      "speaker": "A",
      "line": "不客气！再见！",
      "kr": "천만에요! 안녕히 가세요!",
      "en": "You're welcome! Goodbye!"
    },
    {
      "speaker": "B",
      "line": "再见！",
      "kr": "안녕히 가세요!",
      "en": "Goodbye!"
    }
  ],
  "grammar": [
    {
      "title": "叫 + 名字",
      "explanation_zh": "用\"叫\"来介绍或询问名字。",
      "explanation_kr": "'叫'로 이름을 소개하거나 물을 수 있습니다.",
      "explanation_en": "Use \"叫\" to introduce or ask for names.",
      "example": {
        "zh": "我叫李明。",
        "pinyin": "Wǒ jiào Lǐ Míng.",
        "kr": "저는 이명이에요.",
        "en": "I'm Li Ming."
      }
    },
    {
      "title": "什么 — 疑问词",
      "explanation_zh": "\"什么\"用于询问事物或名字。",
      "explanation_kr": "'什么'은 사물이나 이름을 물을 때 사용합니다.",
      "explanation_en": "\"什么\" is used to ask about things or names.",
      "example": {
        "zh": "你叫什么名字？",
        "pinyin": "Nǐ jiào shénme míngzi?",
        "kr": "이름이 뭐예요?",
        "en": "What's your name?"
      }
    }
  ],
