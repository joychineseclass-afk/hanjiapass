  "grammar": [
    {
      "title": "礼貌表达：感谢与回应",
      "explanation_zh": "别人帮助你时说“谢谢”，对方可以回答“没关系”或“不客气”。",
      "explanation_kr": "도움을 받았을 때 '谢谢'라고 말하고, 상대는 '没关系' 또는 '不客气'라고 답할 수 있습니다.",
      "example": "A：谢谢！ B：没关系！"
    },
    {
      "title": "对不起 — 表达道歉",
      "explanation_zh": "做错事情或打扰别人时使用“对不起”。",
      "explanation_kr": "실수했거나 상대를 방해했을 때 '对不起'를 사용합니다.",
      "example": "对不起，我来晚了。"
    }
  ],
