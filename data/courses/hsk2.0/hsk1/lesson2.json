      "lines": [
        { "speaker": "A", "text": "你好！我叫李明。", "translation": { "en": "Hello! I'm Li Ming.", "kr": "안녕! 나는 이명이야.", "jp": "こんにちは。李明です。" }, "pinyin": "Nǐ hǎo! Wǒ jiào Lǐ Míng." },
        { "speaker": "B", "text": "你好！我叫安娜。", "translation": { "en": "Hello! I'm Anna.", "kr": "안녕! 나는 안나야.", "jp": "こんにちは。安娜です。" }, "pinyin": "Nǐ hǎo! Wǒ jiào Ānnà." },
        { "speaker": "A", "text": "我是学生。你呢？", "translation": { "en": "I'm a student. And you?", "kr": "나는 학생이야. 너는?", "jp": "私は学生です。あなたは？" }, "pinyin": "Wǒ shì xuésheng. Nǐ ne?" },
        { "speaker": "B", "text": "我也是学生。", "translation": { "en": "I'm a student too.", "kr": "나도 학생이야.", "jp": "私も学生です。" }, "pinyin": "Wǒ yě shì xuésheng." }
      ]
    }
  ],
  "dialogueCards": [],
  "grammar": [
    {
      "pattern": "我叫 + 名字",
      "pinyin": "wǒ jiào + míngzi",
      "explain": {
        "zh": "用「叫」介绍自己的名字。结构：我叫 + 名字",
        "kr": "「叫」로 이름을 소개합니다. 구조: 我叫 + 이름",
        "en": "Use 叫 to introduce your name. Pattern: 我叫 + name",
        "jp": "「叫」で名前を紹介します。構造：我叫 + 名前"
      },
      "example": {
        "zh": "我叫李明。",
        "pinyin": "Wǒ jiào Lǐ Míng.",
        "translation": { "kr": "저는 이명이에요.", "jp": "私は李明です。", "en": "I'm Li Ming." }
      }
    },
    {
      "pattern": "我是 + 身份",
      "pinyin": "wǒ shì + shēnfèn",
      "explain": {
        "zh": "用「是」介绍身份。结构：我是 + 学生/老师/医生……",
        "kr": "「是」로 신분을 말합니다. 구조: 我是 + 학생/선생님…",
        "en": "Use 是 to state identity. Pattern: 我是 + student/teacher…",
        "jp": "「是」で身分を言います。構造：我是 + 学生/老师…"
      },
      "example": {
        "zh": "我是学生。",
        "pinyin": "Wǒ shì xuésheng.",
        "translation": { "kr": "저는 학생이에요.", "jp": "私は学生です。", "en": "I'm a student." }
      }
    },
    {
      "pattern": "呢（追问）",
      "pinyin": "ne",
      "explain": {
        "zh": "「呢」用在句末，表示追问对方同样的问题。如：你呢？= 你叫什么名字呢？/ 你呢？= 你也是学生吗？",
        "kr": "「呢」는 문장 끝에 써서 상대에게 같은 걸 묻습니다. 你呢？= 너는?",
        "en": "呢 at the end asks the same question to the other. 你呢？= And you?",
        "jp": "「呢」は文末で相手に同じことを聞く。「你呢？」＝あなたは？"
      },
      "example": {
        "zh": "我叫王明。你呢？我叫Anna。我是学生。你呢？我也是学生。",
        "pinyin": "Wǒ jiào Wáng Míng. Nǐ ne? Wǒ jiào Anna. Wǒ shì xuésheng. Nǐ ne? Wǒ yě shì xuésheng.",
        "translation": { "kr": "나는 왕명이야. 너는? 나는 Anna. 나는 학생이야. 너는? 나도 학생이야.", "jp": "王明です。あなたは？Annaです。学生です。あなたは？私も学生です。", "en": "I'm Wang Ming. And you? I'm Anna. I'm a student. And you? I'm a student too." }
      }
    }
  ],
