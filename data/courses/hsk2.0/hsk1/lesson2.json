  "dialogue": [
    {
      "title": "会话1",
      "lines": [
        { "speaker": "A", "zh": "你叫什么名字？", "pinyin": "Nǐ jiào shénme míngzi?", "kr": "이름이 뭐예요?" },
        { "speaker": "B", "zh": "我叫小明。", "pinyin": "Wǒ jiào Xiǎomíng.", "kr": "저는 샤오밍이에요." }
      ]
    },
    {
      "title": "会话2",
      "lines": [
        { "speaker": "A", "zh": "我叫小美。", "pinyin": "Wǒ jiào Xiǎoměi.", "kr": "저는 샤오메이예요." },
        { "speaker": "B", "zh": "很高兴认识你。", "pinyin": "Hěn gāoxìng rènshi nǐ.", "kr": "만나서 반가워요." }
      ]
    }
  ],
  "grammar": [
    {
      "title": "叫 + 名字",
      "explanation_zh": "用「叫」来介绍或询问名字。",
      "explanation_kr": "'叫'로 이름을 소개하거나 물을 수 있습니다.",
      "explanation_en": "Use 叫 to introduce or ask for names.",
