    {
      "title": "什么 — 疑问词",
      "explanation_zh": "「什么」用于询问事物或名字。",
      "explanation_kr": "'什么'은 사물이나 이름을 물을 때 사용합니다.",
      "explanation_en": "什么 is used to ask about things or names.",
      "example": { "zh": "你叫什么名字？", "pinyin": "Nǐ jiào shénme míngzi?", "kr": "이름이 뭐예요?", "en": "What's your name?" }
    },
    {
      "title": "A 是 B",
      "explanation_zh": "「是」表示等同关系。",
      "explanation_kr": "'是'는 동일 관계를 나타냅니다.",
      "explanation_en": "是 indicates equality.",
      "example": { "zh": "我是学生。", "pinyin": "Wǒ shì xuésheng.", "kr": "저는 학생이에요.", "en": "I am a student." }
    }
