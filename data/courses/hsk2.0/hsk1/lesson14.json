  "grammar": [
    {
      "pattern": "一起 + 动词",
      "pinyin": "yīqǐ + dòngcí",
      "explain": {
        "zh": "「一起」表示“一块儿做某事”，放在动词前。我们一起吃饭吧。",
        "kr": "「一起」는 \"함께 ~하다\", 동사 앞에 씁니다. 我们一起吃饭吧.",
        "en": "一起 = together, before the verb. 我们一起吃饭吧 = Let's eat together.",
        "jp": "「一起」は「一緒に」。動詞の前。我们一起吃饭吧。"
      },
      "example": {
        "zh": "我们一起吃饭吧。好啊！那我们去那家面馆吧。好，我们走吧。",
        "pinyin": "Wǒmen yīqǐ chī fàn ba. Hǎo a! Nà wǒmen qù nà jiā miànguǎn ba. Hǎo, wǒmen zǒu ba.",
        "translation": { "kr": "우리 같이 밥 먹자. 좋아! 그럼 그 면관 가자. 가자.", "jp": "一緒にご飯食べよう。いいよ。あの店行こう。行こう。", "en": "Let's eat together. Sure! Let's go to that noodle shop. Let's go." }
      }
    },
    {
      "pattern": "想 + 动词",
      "pinyin": "xiǎng + dòngcí",
      "explain": {
        "zh": "「想」后接动词表示“想做什么”。你想吃什么？我想吃面条。",
        "kr": "「想」 뒤에 동사 = ~하고 싶다. 你想吃什么？我想吃面条.",
        "en": "想 + verb = want to do. 你想吃什么？= What do you want to eat?",
        "jp": "「想」+動詞＝〜したい。你想吃什么？我想吃面条。"
      },
      "example": {
        "zh": "你想吃什么？我想吃面条。",
        "pinyin": "Nǐ xiǎng chī shénme? Wǒ xiǎng chī miàntiáo.",
        "translation": { "kr": "뭐 먹고 싶어? 나는 면 먹고 싶어.", "jp": "何が食べたい？麺が食べたい。", "en": "What do you want to eat? I want noodles." }
      }
    }
  ],
