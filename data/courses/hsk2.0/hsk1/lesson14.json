      "lines": [
        { "speaker": "A", "text": "你吃什么？", "pinyin": "Nǐ chī shénme?", "translation": { "kr": "뭘 먹어요?", "en": "What do you eat?", "jp": "何を食べますか？" } },
        { "speaker": "B", "text": "我吃米饭和菜。", "pinyin": "Wǒ chī mǐfàn hé cài.", "translation": { "kr": "밥이랑 반찬 먹어요.", "en": "I eat rice and dishes.", "jp": "ご飯と料理を食べます。" } },
        { "speaker": "A", "text": "你喝水吗？", "pinyin": "Nǐ hē shuǐ ma?", "translation": { "kr": "물 마셔요?", "en": "Do you drink water?", "jp": "水を飲みますか？" } },
        { "speaker": "B", "text": "喝。", "pinyin": "Hē.", "translation": { "kr": "마셔요.", "en": "Yes.", "jp": "飲みます。" } }
      ]
    }
  ],
  "grammar": [
    {
      "title": "吃 / 喝 + 宾语",
      "explanation_zh": "「吃」用于固体，「喝」用于液体。",
      "explanation_kr": "'吃'는 고체, '喝'는 액체에 사용합니다.",
      "explanation_en": "吃 for solid, 喝 for liquid.",
      "example": {
        "zh": "吃饭，喝水",
        "pinyin": "chī fàn, hē shuǐ",
        "kr": "밥 먹다, 물 마시다",
        "en": "eat, drink water"
      },
      "explain": {
        "jp": "「吃」は固体、「喝」は液体に使います。",
        "en": "吃 for solid, 喝 for liquid.",
        "kr": "'吃'는 고체, '喝'는 액체에 사용합니다.",
        "zh": "「吃」用于固体，「喝」用于液体。"
      }
    },
    {
      "title": "和",
      "explanation_zh": "「和」连接名词。",
      "explanation_kr": "'和'는 명사를 연결합니다.",
      "explanation_en": "和 connects nouns.",
      "example": {
        "zh": "米饭和菜",
        "pinyin": "mǐfàn hé cài",
        "kr": "밥과 요리",
        "en": "rice and dishes"
      },
      "explain": {
        "jp": "「和」は名詞をつなぎます。",
        "en": "和 connects nouns.",
        "kr": "'和'는 명사를 연결합니다.",
        "zh": "「和」连接名词。"
      }
    }
