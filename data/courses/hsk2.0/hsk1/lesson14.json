  "grammar": [
    {
      "pattern": "一起 + 动词",
      "pinyin": "yīqǐ + dòngcí",
      "explanation": {
        "kr": "「一起」는 \"함께 ~하다\", 동사 앞에 씁니다. 我们一起吃饭吧.",
        "en": "一起 = together, before the verb. 我们一起吃饭吧 = Let's eat together.",
        "jp": "「一起」は「一緒に」。動詞の前。我们一起吃饭吧。"
      },
      "example": {
        "text": "我们一起吃饭吧。",
        "pinyin": "Wǒ men yì qǐ chī fàn ba 。",
        "translation": {
          "kr": "같이 밥 먹어요.",
          "en": "Let's eat together.",
          "jp": "一緒にご飯を食べましょう。"
        }
      }
    },
    {
      "pattern": "想 + 动词",
      "pinyin": "xiǎng + dòngcí",
      "explanation": {
        "kr": "「想」 뒤에 동사 = ~하고 싶다. 你想吃什么？我想吃面条.",
        "en": "想 + verb = want to do. 你想吃什么？= What do you want to eat?",
        "jp": "「想」+動詞＝〜したい。你想吃什么？我想吃面条。"
      },
      "example": {
        "text": "你想吃什么？好啊！我想吃面条。那我们去那家面馆吧。好，我们走吧。",
        "pinyin": "Nǐ xiǎng chī shén me ？ Hǎo a ！ Wǒ xiǎng chī miàn tiáo 。 Nà wǒ men qù nà jiā miàn guǎn ba 。 Hǎo ， wǒ men zǒu ba 。",
        "translation": {
          "kr": "뭘 먹고 싶어요? 좋아요! 면 먹고 싶어요. 그럼 그 면관에 가요. 좋아요, 가요.",
          "en": "What do you want to eat? Great! I want to eat noodles. Then let's go to that noodle shop. OK, let's go.",
          "jp": "何を食べたいですか？ いいですね！ 麺を食べたいです。 じゃああの麺屋に行きましょう。 はい、行きましょう。"
        }
      }
    }
