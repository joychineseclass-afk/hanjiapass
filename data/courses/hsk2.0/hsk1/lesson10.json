      },
      "lines": [
        {
          "speaker": "A",
          "text": "他是老师吗？",
          "translation": {
            "en": "Is he a teacher?",
            "kr": "Is he a teacher?",
            "jp": "Is he a teacher?"
          },
          "pinyin": "tā shì lǎo shī ma ？"
        },
        {
          "speaker": "B",
          "text": "是，他是老师。我们都是学生。",
          "translation": {
            "en": "Yes, he's a teacher. We're all students.",
            "kr": "Yes, he's a teacher. We're all students.",
            "jp": "Yes, he's a teacher. We're all students."
          },
          "pinyin": "shì ， tā shì lǎo shī 。 wǒ men dōu shì xué shēng 。"
        },
        {
          "speaker": "A",
          "text": "她呢？",
          "translation": {
            "en": "What about her?",
            "kr": "What about her?",
            "jp": "What about her?"
          },
          "pinyin": "tā ne ？"
        },
        {
          "speaker": "B",
          "text": "她也是老师。",
          "translation": {
            "en": "She's a teacher too.",
            "kr": "She's a teacher too.",
            "jp": "She's a teacher too."
          },
          "pinyin": "tā yě shì lǎo shī 。"
        }
      ]
    }
  ],
  "grammar": [
    {
      "title": "在 + 地点",
      "explanation_zh": "「在」表示存在或位置。",
      "explanation_kr": "'在'는 존재나 위치를 나타냅니다.",
      "explanation_en": "在 indicates location.",
      "example": {
        "zh": "我在学校。",
        "pinyin": "Wǒ zài xuéxiào.",
        "kr": "저는 학교에 있어요.",
        "en": "I'm at school."
      },
      "explain": {
        "jp": "「在」は存在や位置を表します。",
        "en": "在 indicates location.",
        "kr": "'在'는 존재나 위치를 나타냅니다.",
        "zh": "「在」表示存在或位置。"
      }
    },
    {
      "title": "上 / 下 / 里",
      "explanation_zh": "方位词：上、下、前面、后面、里。",
      "explanation_kr": "방향어: 上, 下, 前面, 后面, 里.",
      "explanation_en": "Direction words.",
      "example": {
        "zh": "在桌子上",
        "pinyin": "zài zhuōzi shàng",
        "kr": "책상 위에",
        "en": "on the table"
      },
      "explain": {
        "jp": "方位詞：上、下、前面、后面、里。",
        "en": "Direction words.",
        "kr": "방향어: 上, 下, 前面, 后面, 里.",
        "zh": "方位词：上、下、前面、后面、里。"
      }
    }
