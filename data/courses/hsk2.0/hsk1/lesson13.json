          "zh": "我喜欢狗。",
          "pinyin": "Wǒ xǐhuan gǒu.",
          "kr": "저는 개를 좋아해요.",
          "text": "我喜欢狗。",
          "translation": {
            "kr": "저는 개를 좋아해요.",
            "en": "I like dogs.",
            "jp": "犬が好きです。"
