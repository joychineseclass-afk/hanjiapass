  "grammar": [
    {
      "pattern": "请问（礼貌询问）",
      "pinyin": "qǐngwèn",
      "explain": {
        "zh": "「请问」放在问句前表示礼貌地询问。请问你找谁？= 礼貌地问“你找谁？”。",
        "kr": "「请问」는 질문 앞에 써서 예의 있게 묻습니다. 请问你找谁?",
        "en": "请问 before a question = May I ask (polite). 请问你找谁？",
        "jp": "「请问」は質問の前で丁寧に聞く。请问你找谁？"
      },
      "example": {
        "zh": "请问你找谁？我找王老师。",
        "pinyin": "Qǐngwèn nǐ zhǎo shéi? Wǒ zhǎo Wáng lǎoshī.",
        "translation": { "kr": "누구 찾으세요? 왕 선생님 찾아요.", "jp": "どなたをお探しですか？王老师をお願いします。", "en": "Who are you looking for? I'm looking for Teacher Wang." }
      }
    },
    {
      "pattern": "找 + 人",
      "pinyin": "zhǎo + rén",
      "explain": {
        "zh": "「找」表示寻找。找+人：我找王老师。问对方找谁：你找谁？",
        "kr": "「找」는 찾다. 找+사람: 我找王老师. 你找谁?",
        "en": "找 = to look for. 找 + person: 我找王老师. 你找谁？",
        "jp": "「找」は探す。找+人：我找王老师。你找谁？"
      },
      "example": {
        "zh": "请问你找谁？我找王老师。",
        "pinyin": "Qǐngwèn nǐ zhǎo shéi? Wǒ zhǎo Wáng lǎoshī.",
        "translation": { "kr": "누구 찾으세요? 왕 선생님 찾아요.", "jp": "どなたをお探しですか？王老师です。", "en": "Who are you looking for? I'm looking for Teacher Wang." }
      }
    },
    {
      "pattern": "能 + 动词",
      "pinyin": "néng + dòngcí",
      "explain": {
        "zh": "「能」表示能力或请求许可，后接动词。能+动词：能等一下、能来。",
        "kr": "「能」는 능력이나 허가 요청. 能+동사: 能等一下.",
        "en": "能 = can / may (ability or permission). 能 + verb: 能等一下.",
        "jp": "「能」は可能・許可。能+動詞：能等一下。"
      },
      "example": {
        "zh": "那我能等一下吗？可以。",
        "pinyin": "Nà wǒ néng děng yīxià ma? Kěyǐ.",
        "translation": { "kr": "그럼 잠깐 기다려도 될까요? 네, 됩니다.", "jp": "少々お待ちしてもいいですか？はい、どうぞ。", "en": "Can I wait a moment? Yes, you can." }
      }
    },
    {
      "pattern": "能……吗？",
      "pinyin": "néng … ma",
      "explain": {
        "zh": "「能……吗？」用来请求许可，意思是“可以……吗？”回答常用「可以」或「不能」。",
        "kr": "「能……吗?」는 허가를 요청. \"~해도 될까요?\" 답: 可以/不能.",
        "en": "能……吗？= May I ...? / Can I ...? Answer: 可以 or 不能.",
        "jp": "「能……吗？」は許可を求める。「〜してもいいですか？」答は「可以」或「不能」。"
      },
      "example": {
        "zh": "那我能等一下吗？可以。",
        "pinyin": "Nà wǒ néng děng yīxià ma? Kěyǐ.",
        "translation": { "kr": "그럼 잠깐 기다려도 될까요? 네.", "jp": "少々待ってもいいですか？はい。", "en": "Can I wait a moment? Yes." }
      }
    }
  ],
