      "speaker": "A",
      "text": "你几岁？",
      "pinyin": "Nǐ jǐ suì ？",
      "translation": {
        "kr": "몇 살이에요?",
        "en": "How old are you?",
        "jp": "何歳ですか？"
      }
    },
    {
      "speaker": "B",
      "text": "我十岁。",
      "pinyin": "Wǒ shí suì 。",
      "translation": {
        "kr": "저는 열 살이에요.",
        "en": "I'm ten years old.",
        "jp": "十歳です。"
      }
    },
    {
      "speaker": "A",
      "text": "你女儿几岁？",
      "pinyin": "Nǐ nǚ'ér jǐ suì?",
      "translation": {
        "kr": "딸은 몇 살이에요?",
        "en": "How old is your daughter?",
        "jp": "あなたの娘は何歳ですか？"
      }
    },
    {
      "speaker": "B",
      "text": "我女儿五岁。",
      "pinyin": "Wǒ nǚ'ér wǔ suì.",
      "translation": {
        "kr": "제 딸은 다섯 살이에요.",
        "en": "My daughter is five years old.",
        "jp": "私の娘は五歳です。"
      }
    },
    {
      "speaker": "A",
      "text": "这是你儿子吗？",
      "pinyin": "Zhè shì nǐ érzi ma?",
