  "grammar": [
    {
      "pattern": "几岁 / 多大",
      "pinyin": "jǐ suì / duō dà",
      "explanation": {
        "kr": "나이를 물을 때 「你几岁?」或「你多大?」. 답은 「숫자+岁」.",
        "en": "Ask age with 你几岁? or 你多大? Answer with number + 岁.",
        "jp": "年齢は「你几岁？」或「你多大？」で聞く。答えは「数字+岁」。"
      },
      "example": {
        "text": "你几岁？",
        "pinyin": "Nǐ jǐ suì ？",
        "translation": {
          "kr": "몇 살이에요?",
          "en": "How old are you?",
          "jp": "何歳ですか？"
        }
      }
    },
    {
      "pattern": "数字 + 岁",
      "pinyin": "shùzì + suì",
      "explanation": {
        "kr": "나이를 말할 때 숫자 뒤에 「岁」. 他呢？= 그 사람은?",
        "en": "Say age with number + 岁. 他呢？= And him? (how old is he?)",
        "jp": "年齢は「数字+岁」。他呢？＝彼は？"
      },
      "example": {
        "text": "我十岁。你多大？我二十二岁。",
        "pinyin": "Wǒ shí suì 。 Nǐ duō dà ？ Wǒ èr shí èr suì 。",
        "translation": {
          "kr": "저는 열 살이에요. 나이가 어떻게 되세요? 저는 스물두 살이에요.",
          "en": "I'm ten years old. How old are you? I'm twenty-two years old.",
          "jp": "十歳です。 おいくつですか？ 二十二歳です。"
        }
      }
    }
  ],
