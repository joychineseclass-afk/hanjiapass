      "lines": [
        {
          "speaker": "A",
          "text": "现在几点？",
          "translation": {
            "en": "What time is it now?",
            "kr": "What time is it now?",
            "jp": "What time is it now?"
          },
          "pinyin": "xiàn zài jǐ diǎn ？"
        },
        {
          "speaker": "B",
          "text": "现在三点。",
          "translation": {
            "en": "It's three o'clock now.",
            "kr": "It's three o'clock now.",
            "jp": "It's three o'clock now."
          },
          "pinyin": "xiàn zài sān diǎn 。"
        },
        {
          "speaker": "A",
          "text": "你什么时候回家？",
          "translation": {
            "en": "When do you go home?",
            "kr": "When do you go home?",
            "jp": "When do you go home?"
          },
          "pinyin": "nǐ shén me shí hòu huí jiā ？"
        },
        {
          "speaker": "B",
          "text": "我下午五点回家。",
          "translation": {
            "en": "I go home at five in the afternoon.",
            "kr": "I go home at five in the afternoon.",
            "jp": "I go home at five in the afternoon."
          },
          "pinyin": "wǒ xià wǔ wǔ diǎn huí jiā 。"
        }
      ]
    }
  ],
