  "dialogueCards": [
    {
      "title": {
        "zh": "会话1",
        "kr": "회화1",
        "en": "Session 1",
        "jp": "会話1"
      },
      "lines": [
        {
          "speaker": "A",
          "zh": "你家有几个人？",
          "pinyin": "Nǐ jiā yǒu jǐ gè rén?",
          "kr": "가족이 몇 명이에요?",
          "text": "你家有几个人？",
          "translation": {
            "kr": "가족이 몇 명이에요?",
            "en": "How many people are in your family?",
            "jp": "ご家族は何人ですか？"
          }
        },
        {
          "speaker": "B",
          "zh": "我家有四个人。",
          "pinyin": "Wǒ jiā yǒu sì gè rén.",
          "kr": "우리 가족은 네 명이에요.",
          "text": "我家有四个人。",
          "translation": {
            "kr": "우리 가족은 네 명이에요.",
            "en": "There are four people in my family.",
            "jp": "私の家族は4人です。"
          }
        }
      ]
    },
    {
      "title": {
        "zh": "会话2",
        "kr": "회화2",
        "en": "Session 2",
        "jp": "会話2"
      },
      "lines": [
        {
          "speaker": "A",
          "zh": "你爸爸是老师吗？",
          "pinyin": "Nǐ bàba shì lǎoshī ma?",
          "kr": "아버지는 선생님이에요?",
          "text": "你爸爸是老师吗？",
          "translation": {
            "kr": "아버지는 선생님이에요?",
            "en": "Is your dad a teacher?",
            "jp": "お父さんは先生ですか？"
          }
        },
        {
          "speaker": "B",
          "zh": "不是，他是医生。",
          "pinyin": "Bú shì, tā shì yīshēng.",
          "kr": "아니요, 그는 의사예요.",
          "text": "不是，他是医生。",
          "translation": {
            "kr": "아니요, 그는 의사예요.",
            "en": "No, he's a doctor.",
            "jp": "いいえ、彼は医者です。"
          }
        }
      ]
    },
    {
      "title": {
        "zh": "会话3",
        "kr": "회화3",
        "en": "Session 3",
        "jp": "会話3"
      },
      "lines": [
        {
          "speaker": "A",
          "zh": "她是谁？",
          "pinyin": "Tā shì shéi?",
          "kr": "그녀는 누구예요?",
          "text": "她是谁？",
          "translation": {
            "kr": "그녀는 누구예요?",
            "en": "Who is she?",
            "jp": "彼女は誰ですか？"
          }
        },
        {
          "speaker": "B",
          "zh": "她是我妈妈。",
          "pinyin": "Tā shì wǒ māma.",
          "kr": "그녀는 우리 엄마예요.",
          "text": "她是我妈妈。",
          "translation": {
            "kr": "그녀는 우리 엄마예요.",
            "en": "She is my mom.",
            "jp": "彼女は私の母です。"
          }
        }
      ]
    }
