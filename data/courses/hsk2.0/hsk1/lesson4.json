  "dialogue": [
    {
      "title": "会话1",
      "lines": [
        { "speaker": "A", "zh": "你家有几个人？", "pinyin": "Nǐ jiā yǒu jǐ gè rén?", "kr": "가족이 몇 명이에요?" },
        { "speaker": "B", "zh": "我家有四个人。", "pinyin": "Wǒ jiā yǒu sì gè rén.", "kr": "우리 가족은 네 명이에요." }
      ]
    },
    {
      "title": "会话2",
      "lines": [
        { "speaker": "A", "zh": "你爸爸是老师吗？", "pinyin": "Nǐ bàba shì lǎoshī ma?", "kr": "아버지는 선생님이에요?" },
        { "speaker": "B", "zh": "不是，他是医生。", "pinyin": "Bú shì, tā shì yīshēng.", "kr": "아니요, 그는 의사예요." }
      ]
    },
    {
      "title": "会话3",
      "lines": [
        { "speaker": "A", "zh": "她是谁？", "pinyin": "Tā shì shéi?", "kr": "그녀는 누구예요?" },
        { "speaker": "B", "zh": "她是我妈妈。", "pinyin": "Tā shì wǒ māma.", "kr": "그녀는 우리 엄마예요." }
      ]
    }
  ],
  "grammar": [
    { "title": "的 — 所属", "explanation_zh": "「的」表示所属关系。", "explanation_kr": "'的'는 소유 관계를 나타냅니다.", "explanation_en": "的 indicates possession.", "example": { "zh": "我爸爸", "pinyin": "wǒ bàba", "kr": "우리 아빠", "en": "my dad" } },
    { "title": "他 / 她", "explanation_zh": "「他」指男性，「她」指女性。", "explanation_kr": "'他'는 남성, '她'는 여성을 가리킵니다.", "explanation_en": "他 for male, 她 for female.", "example": { "zh": "他是学生。她是老师。", "pinyin": "Tā shì xuésheng. Tā shì lǎoshī.", "kr": "그는 학생. 그녀는 선생님.", "en": "He is a student. She is a teacher." } }
  ],
