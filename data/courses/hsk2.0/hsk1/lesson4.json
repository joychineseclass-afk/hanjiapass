  "grammar": [
    {
      "pattern": "这 / 那",
      "pinyin": "zhè / nà",
      "explain": {
        "zh": "「这」指近处，「那」指远处。用来指人或物。",
        "kr": "'这'는 가까운 것, '那'는 먼 것. 사람이나 물건을 가리킬 때 씁니다.",
        "en": "这 = this (near), 那 = that (far). Used to point to people or things.",
        "jp": "「这」は近く、「那」は遠く。人や物を指します。"
      },
      "example": {
        "zh": "这是谁？那是谁？",
        "pinyin": "Zhè shì shéi? Nà shì shéi?",
        "translation": { "kr": "이 사람 누구야? 저 사람 누구야?", "jp": "これは誰？あれは誰？", "en": "Who is this? Who is that?" }
      }
    }
  ],
