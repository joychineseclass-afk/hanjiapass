  "grammar": [
    {
      "pattern": "谁",
      "pinyin": "shéi",
      "explanation": {
        "kr": "「谁」는 \"누구\"를 묻습니다. 他是谁？답: 他是+호칭.",
        "en": "谁 means who. Pattern: 他是谁? Answer: 他是 + person.",
        "jp": "「谁」は「誰」を聞く。他是谁？答：他是+呼称。"
      },
      "example": {
        "text": "他是谁？",
        "pinyin": "Tā shì shuí ？",
        "translation": {
          "kr": "그는 누구예요?",
          "en": "Who is he?",
          "jp": "彼は誰ですか？"
        }
      }
    },
    {
      "pattern": "的（表示所属）",
      "pinyin": "de",
      "explanation": {
        "kr": "「的」는 명사 앞에서 소유를 나타냅니다. 我的爸爸 = 나의 아빠.",
        "en": "的 before a noun shows possession. 我的爸爸 = my dad.",
        "jp": "「的」は名詞の前で所属を表す。我的爸爸＝私の父。"
      },
      "example": {
        "text": "他是我的爸爸。",
        "pinyin": "Tā shì wǒ de bà ba 。",
        "translation": {
          "kr": "그는 제 아빠예요.",
          "en": "He is my dad.",
          "jp": "彼は私の父です。"
        }
      }
    },
    {
      "pattern": "很（程度）",
      "pinyin": "hěn",
      "explanation": {
        "kr": "「很」는 형용사 앞에서 정도를 나타냅니다. 很爱, 很好.",
        "en": "很 before an adjective means \"very\". 很爱 = love very much.",
        "jp": "「很」は形容詞の前で程度を表す。很爱、很好。"
      },
      "example": {
        "text": "爱，我很爱他们。她呢？她是我的妈妈。你爱爸爸妈妈吗？",
        "pinyin": "Ài ， wǒ hěn ài tā men 。 Tā ne ？ Tā shì wǒ de mā ma 。 Nǐ ài bà ba mā ma ma ？",
        "translation": {
          "kr": "사랑해요, 저는 그들을 아주 사랑해요. 그녀는요? 그녀는 제 엄마예요. 아빠 엄마 사랑해요?",
          "en": "Yes, I love them very much. What about her? She is my mom. Do you love your mom and dad?",
          "jp": "はい、とても愛しています。 彼女は？ 彼女は私の母です。 お父さんとお母さんを愛していますか？"
        }
      }
    }
  ],
