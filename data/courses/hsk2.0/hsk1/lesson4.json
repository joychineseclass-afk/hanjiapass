    {
      "title": "谁 — 疑问代词",
      "explanation_zh": "“谁”用于询问人物。",
      "explanation_kr": "'谁'는 사람을 물을 때 사용합니다.",
      "example": "他是谁？"
    },
    {
      "title": "认识 — 表示认识某人",
      "explanation_zh": "“认识”表示知道或见过某人。",
      "explanation_kr": "'认识'는 어떤 사람을 알고 있음을 나타냅니다.",
      "example": "我认识他。"
    },
    {
      "title": "我们 / 你们 / 他们",
      "explanation_zh": "在“我、你、他”后加“们”表示复数。",
      "explanation_kr": "'们'을 붙이면 복수형이 됩니다.",
      "example": "我们是朋友。"
    }
