  "grammar": [
    {
      "title": "的 — 所属",
      "explanation_zh": "「的」表示所属关系。",
      "explanation_kr": "'的'는 소유 관계를 나타냅니다.",
      "explanation_en": "的 indicates possession.",
      "example": {
        "zh": "我爸爸",
        "pinyin": "wǒ bàba",
        "kr": "우리 아빠",
        "en": "my dad"
      },
      "explain": {
        "jp": "「的」は所有関係を表します。",
        "en": "的 indicates possession.",
        "kr": "'的'는 소유 관계를 나타냅니다.",
        "zh": "「的」表示所属关系。"
      }
    },
    {
      "title": "他 / 她",
      "explanation_zh": "「他」指男性，「她」指女性。",
      "explanation_kr": "'他'는 남성, '她'는 여성을 가리킵니다.",
      "explanation_en": "他 for male, 她 for female.",
      "example": {
        "zh": "他是学生。她是老师。",
        "pinyin": "Tā shì xuésheng. Tā shì lǎoshī.",
        "kr": "그는 학생. 그녀는 선생님.",
        "en": "He is a student. She is a teacher."
      },
      "explain": {
        "jp": "「他」は男性、「她」は女性を指します。",
        "en": "他 for male, 她 for female.",
        "kr": "'他'는 남성, '她'는 여성을 가리킵니다.",
        "zh": "「他」指男性，「她」指女性。"
      }
    }
  ],
