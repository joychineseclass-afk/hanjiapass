      "title": { "zh": "主对话", "kr": "대화", "en": "Dialogue", "jp": "会話" },
      "lines": [
        { "speaker": "A", "text": "你有兄弟姐妹吗？", "translation": { "en": "Do you have siblings?", "kr": "형제자매 있어?", "jp": "兄弟姉妹はいますか？" }, "pinyin": "Nǐ yǒu xiōngdì jiěmèi ma?" },
        { "speaker": "B", "text": "我有一个妹妹。", "translation": { "en": "I have one younger sister.", "kr": "나는 여동생이 한 명 있어.", "jp": "妹が一人います。" }, "pinyin": "Wǒ yǒu yī gè mèimei." },
        { "speaker": "A", "text": "你有哥哥吗？", "translation": { "en": "Do you have an older brother?", "kr": "오빠 있어?", "jp": "兄はいますか？" }, "pinyin": "Nǐ yǒu gēge ma?" },
        { "speaker": "B", "text": "没有。", "translation": { "en": "No.", "kr": "없어.", "jp": "いいえ。" }, "pinyin": "Méiyǒu." },
        { "speaker": "A", "text": "你家有几口人？", "translation": { "en": "How many people in your family?", "kr": "너희 집 식구가 몇 명이야?", "jp": "家族は何人ですか？" }, "pinyin": "Nǐ jiā yǒu jǐ kǒu rén?" },
        { "speaker": "B", "text": "我家有四口人。", "translation": { "en": "There are four people in my family.", "kr": "우리 집은 네 식구야.", "jp": "四人家族です。" }, "pinyin": "Wǒ jiā yǒu sì kǒu rén." }
      ]
    }
  ],
