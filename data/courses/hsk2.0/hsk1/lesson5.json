  "originalDialogues": [
    {
      "title": { "zh": "会话1", "kr": "회화1", "en": "Session 1", "jp": "会話1" },
      "lines": [
        { "speaker": "A", "text": "你家有几个人？", "pinyin": "Nǐ jiā yǒu jǐ gè rén?", "translation": { "kr": "가족이 몇 명이에요?", "en": "How many people are in your family?", "jp": "家族は何人ですか？" } },
        { "speaker": "B", "text": "我家有五个人。", "pinyin": "Wǒ jiā yǒu wǔ gè rén.", "translation": { "kr": "저희 가족은 다섯 명이에요.", "en": "There are five people in my family.", "jp": "家族は5人です。" } }
      ]
    },
    {
      "title": { "zh": "会话2", "kr": "회화2", "en": "Session 2", "jp": "会話2" },
      "lines": [
        { "speaker": "A", "text": "你有几个？", "pinyin": "Nǐ yǒu jǐ gè?", "translation": { "kr": "몇 개 있어요?", "en": "How many do you have?", "jp": "いくつありますか？" } },
        { "speaker": "B", "text": "我有三个。一、二、三、四、五、六、七、八、九、十。", "pinyin": "Wǒ yǒu sān gè. Yī, èr, sān, sì, wǔ, liù, qī, bā, jiǔ, shí.", "translation": { "kr": "세 개 있어요. 하나부터 열까지.", "en": "I have three. One, two, three, four, five, six, seven, eight, nine, ten.", "jp": "3つあります。一から十まで。" } }
      ]
    },
    {
      "title": { "zh": "会话3", "kr": "회화3", "en": "Session 3", "jp": "会話3" },
      "lines": [
        { "speaker": "A", "text": "多少个？", "pinyin": "Duōshao gè?", "translation": { "kr": "몇 개예요?", "en": "How many?", "jp": "いくつですか？" } },
        { "speaker": "B", "text": "十个。零。少吗？少。", "pinyin": "Shí gè. Líng. Shǎo ma? Shǎo.", "translation": { "kr": "열 개. 영. 적어요? 적어요.", "en": "Ten. Zero. Few? Yes, few.", "jp": "10個。ゼロ。少ない？少ない。" } }
      ]
    }
  ],
