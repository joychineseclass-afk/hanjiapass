  "grammar": [
    {
      "pattern": "有 / 没有",
      "pinyin": "yǒu / méiyǒu",
      "explain": {
        "zh": "「有」表示拥有，「没有」表示不拥有。",
        "kr": "'有'는 있다, '没有'는 없다.",
        "en": "有 = to have, 没有 = to not have.",
        "jp": "「有」は持っている、「没有」は持っていない。"
      },
      "example": {
        "zh": "我有妹妹。我没有哥哥。",
        "pinyin": "Wǒ yǒu mèimei. Wǒ méiyǒu gēge.",
        "translation": { "kr": "나는 여동생이 있어. 오빠는 없어.", "jp": "妹がいます。兄はいません。", "en": "I have a younger sister. I don't have an older brother." }
      }
    }
  ],
