  "grammar": [
    {
      "pattern": "哪儿",
      "pinyin": "nǎr",
      "explanation": {
        "kr": "「哪儿」는 장소를 묻습니다. \"어디\". 답: 在+장소.",
        "en": "哪儿 asks for place (where). Answer with 在 + place.",
        "jp": "「哪儿」は場所を聞く（どこ）。答は「在+場所」。"
      },
      "example": {
        "text": "你在哪儿？",
        "pinyin": "Nǐ zài nǎ ér ？",
        "translation": {
          "kr": "어디에 있어요?",
          "en": "Where are you?",
          "jp": "どこにいますか？"
        }
      }
    },
    {
      "pattern": "在 + 地点",
      "pinyin": "zài + dìdiǎn",
      "explanation": {
        "kr": "「在」는 \"~에 있다\". 구조: 사람+在+장소.",
        "en": "在 means to be at a place. Pattern: person + 在 + place.",
        "jp": "「在」は「〜にいる/ある」。人+在+場所。"
      },
      "example": {
        "text": "我在学校。",
        "pinyin": "Wǒ zài xué xiào 。",
        "translation": {
          "kr": "저는 학교에 있어요.",
          "en": "I'm at school.",
          "jp": "学校にいます。"
        }
      }
    },
    {
      "pattern": "和",
      "pinyin": "hé",
      "explanation": {
        "kr": "「和」는 두 명사를 연결합니다. \"와/과\". 我和Anna.",
        "en": "和 connects two nouns (and, with). 我和Anna = Anna and I.",
        "jp": "「和」は二つの名詞をつなぐ（と）。我和Anna。"
      },
      "example": {
        "text": "教室开门了吗？开了。谁在教室里？我和Anna。",
        "pinyin": "Jiào shì kāi mén le ma ？ Kāi le 。 Shuí zài jiào shì lǐ ？ Wǒ hé A n n a 。",
        "translation": {
          "kr": "교실 문 열렸어요? 열렸어요. 교실에 누가 있어요? Anna랑 저요.",
          "en": "Is the classroom open? It's open. Who is in the classroom? Anna and I.",
          "jp": "教室は開いていますか？ 開いています。 教室に誰がいますか？ Annaと私です。"
        }
      }
    }
