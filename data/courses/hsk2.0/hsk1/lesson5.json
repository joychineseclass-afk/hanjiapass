        },
        {
          "speaker": "B",
          "text": "她是我妈妈。",
          "translation": {
            "en": "She is my mom.",
            "kr": "She is my mom.",
            "jp": "She is my mom."
          },
          "pinyin": "tā shì wǒ mā ma 。"
        },
        {
          "speaker": "A",
          "text": "他是你爸爸吗？",
          "translation": {
            "en": "Is he your dad?",
            "kr": "Is he your dad?",
            "jp": "Is he your dad?"
          },
          "pinyin": "tā shì nǐ bà ba ma ？"
        },
        {
          "speaker": "B",
          "text": "是。我家有五个人：爸爸、妈妈、我、儿子和女儿。",
          "translation": {
            "en": "Yes. There are five people in my family: dad, mom, me, son and daughter.",
            "kr": "Yes. There are five people in my family: dad, mom, me, son and daughter.",
            "jp": "Yes. There are five people in my family: dad, mom, me, son and daughter."
