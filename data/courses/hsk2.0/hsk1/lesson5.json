  "grammar": [
    {
      "title": "几 + 个",
      "explanation_zh": "「几」问小数量，「个」是量词。",
      "explanation_kr": "'几'는 작은 수량을 묻고, '个'는 양사입니다.",
      "explanation_en": "几 asks small quantity, 个 is measure word.",
      "example": {
        "zh": "几个苹果",
        "pinyin": "jǐ gè píngguǒ",
        "kr": "사과 몇 개",
        "en": "how many apples"
      },
      "explain": {
        "jp": "「几」は少ない数量を聞き、「个」は量詞です。",
        "en": "几 asks small quantity, 个 is measure word.",
        "kr": "'几'는 작은 수량을 묻고, '个'는 양사입니다.",
        "zh": "「几」问小数量，「个」是量词。"
      }
    },
    {
      "title": "多少",
      "explanation_zh": "「多少」问数量或价格。",
      "explanation_kr": "'多少'는 수량이나 가격을 묻습니다.",
      "explanation_en": "多少 asks quantity or price.",
      "example": {
        "zh": "多少钱？",
        "pinyin": "Duōshao qián?",
        "kr": "얼마예요?",
        "en": "How much?"
      },
      "explain": {
        "jp": "「多少」は数量や価格を聞きます。",
        "en": "多少 asks quantity or price.",
        "kr": "'多少'는 수량이나 가격을 묻습니다.",
        "zh": "「多少」问数量或价格。"
      }
    }
  ],
