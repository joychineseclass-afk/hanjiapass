  "grammar": [
    {
      "pattern": "怎么 + 动词",
      "pinyin": "zěnme + dòngcí",
      "explain": {
        "zh": "「怎么」后面加动词问方式：你怎么去学校？可以回答：我坐地铁去学校 / 我走路去学校。",
        "kr": "「怎么」 + 동사로 방법을 묻는다. 你怎么去学校？→ 我坐地铁去学校.",
        "en": "怎么 + verb asks about method: 你怎么去学校？→ 我坐地铁去学校。",
        "jp": "「怎么」+動詞で方法を聞く。你怎么去学校？→ 我坐地铁去学校。"
      },
      "example": {
        "zh": "你怎么去学校？我坐地铁去学校。",
        "pinyin": "Nǐ zěnme qù xuéxiào? Wǒ zuò dìtiě qù xuéxiào.",
        "translation": { "kr": "학교 어떻게 가? 지하철 타고 가.", "jp": "どうやって学校へ行く？地下鉄で行く。", "en": "How do you get to school? I take the subway." }
      }
    },
    {
      "pattern": "坐 + 交通工具",
      "pinyin": "zuò + jiāotōng gōngjù",
      "explain": {
        "zh": "用「坐+交通工具」说怎么去：坐地铁、坐公交车。",
        "kr": "「坐+교통수단」으로 어떻게 가는지 말한다: 坐地铁, 坐公交车.",
        "en": "坐 + means of transport: 坐地铁, 坐公交车.",
        "jp": "「坐+乗り物」で移動手段を言う：坐地铁、坐公交车。"
      },
      "example": {
        "zh": "我坐地铁去学校。你呢？你坐公交车去学校。",
        "pinyin": "Wǒ zuò dìtiě qù xuéxiào. Nǐ ne? Nǐ zuò gōngjiāo chē qù xuéxiào.",
        "translation": { "kr": "나는 지하철 타고 학교에 가. 너는? 너는 버스 타고 가.", "jp": "私は地下鉄で学校へ行く。君は？君はバスで行く。", "en": "I take the subway to school. And you? You take the bus." }
      }
    },
    {
      "pattern": "都 / 远 / 不远",
      "pinyin": "dōu / yuǎn / bù yuǎn",
      "explain": {
        "zh": "「都」表示全部；「远 / 不远」表示距离远近：住得远吗？不远。",
        "kr": "「都」는 모두. 「远/不远」은 먼지 안 먼지. 住得远吗？不远.",
        "en": "都 means all; 远 / 不远 describe distance: 住得远吗？不远。",
        "jp": "「都」はみんな。「远／不远」は距離を表す。住得远吗？不远。"
      },
      "example": {
        "zh": "你住得远吗？不远。我和同学都坐地铁去学校。",
        "pinyin": "Nǐ zhù de yuǎn ma? Bù yuǎn. Wǒ hé tóngxué dōu zuò dìtiě qù xuéxiào.",
        "translation": { "kr": "집 멀어? 안 멀어. 나랑 친구들은 다 지하철 타고 학교에 가.", "jp": "家は遠い？遠くない。私とクラスメートはみんな地下鉄で学校へ行く。", "en": "Do you live far away? Not far. My classmates and I all take the subway to school." }
      }
    }
  ],
