  "dialogueCards": [
    {
      "title": { "zh": "会话1", "kr": "회화1", "en": "Session 1", "jp": "会話1" },
      "lines": [
        { "speaker": "A", "text": "你去火车站吗？", "pinyin": "Nǐ qù huǒchēzhàn ma?", "translation": { "kr": "기차역 가요?", "en": "Are you going to the train station?", "jp": "駅に行きますか？" } },
        { "speaker": "B", "text": "去。坐出租车。", "pinyin": "Qù. Zuò chūzūchē.", "translation": { "kr": "가요. 택시 타요.", "en": "Yes. By taxi.", "jp": "行きます。タクシーで。" } }
      ]
    },
    {
      "title": { "zh": "会话2", "kr": "회화2", "en": "Session 2", "jp": "会話2" },
      "lines": [
        { "speaker": "A", "text": "你去北京吗？", "pinyin": "Nǐ qù Běijīng ma?", "translation": { "kr": "베이징 가요?", "en": "Are you going to Beijing?", "jp": "北京に行きますか？" } },
        { "speaker": "B", "text": "是。坐飞机去。", "pinyin": "Shì. Zuò fēijī qù.", "translation": { "kr": "네. 비행기 타고 가요.", "en": "Yes. I'm taking a plane.", "jp": "はい。飛行機で行きます。" } }
      ]
    },
    {
      "title": { "zh": "会话3", "kr": "회화3", "en": "Session 3", "jp": "会話3" },
      "lines": [
        { "speaker": "A", "text": "你看见飞机吗？", "pinyin": "Nǐ kànjiàn fēijī ma?", "translation": { "kr": "비행기 봤어요?", "en": "Do you see the plane?", "jp": "飛行機が見えますか？" } },
        { "speaker": "B", "text": "看见。学生都去。", "pinyin": "Kànjiàn. Xuésheng dōu qù.", "translation": { "kr": "봤어요. 학생들 다 가요.", "en": "Yes. All the students are going.", "jp": "見えます。学生はみんな行きます。" } }
      ]
    }
  ],
  "grammar": [
