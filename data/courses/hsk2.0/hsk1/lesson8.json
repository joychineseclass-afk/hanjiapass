      },
      "lines": [
        {
          "speaker": "A",
          "zh": "现在几点？",
          "pinyin": "Xiànzài jǐ diǎn?",
          "kr": "지금 몇 시예요?",
          "text": "现在几点？",
          "translation": {
            "kr": "지금 몇 시예요?",
            "en": "What time is it now?",
            "jp": "今何時ですか？"
          }
        },
        {
          "speaker": "B",
          "zh": "现在三点。",
          "pinyin": "Xiànzài sān diǎn.",
          "kr": "지금 3시예요.",
          "text": "现在三点。",
          "translation": {
            "kr": "지금 3시예요.",
            "en": "It's three o'clock.",
            "jp": "3時です。"
          }
        }
      ]
    },
    {
      "title": {
        "zh": "会话2",
        "kr": "회화2",
        "en": "Session 2",
        "jp": "会話2"
      },
      "lines": [
        {
          "speaker": "A",
          "zh": "你什么时候回家？",
          "pinyin": "Nǐ shénme shíhou huí jiā?",
          "kr": "언제 집에 돌아가요?",
          "text": "你什么时候回家？",
          "translation": {
            "kr": "언제 집에 돌아가요?",
            "en": "When do you go home?",
            "jp": "いつ家に帰りますか？"
          }
        },
        {
          "speaker": "B",
          "zh": "我下午回家。",
          "pinyin": "Wǒ xiàwǔ huí jiā.",
          "kr": "저는 오후에 집에 돌아가요.",
          "text": "我下午回家。",
          "translation": {
            "kr": "저는 오후에 집에 돌아가요.",
            "en": "I go home in the afternoon.",
            "jp": "午後に帰ります。"
          }
        }
      ]
    },
    {
      "title": {
        "zh": "会话3",
        "kr": "회화3",
        "en": "Session 3",
        "jp": "会話3"
      },
      "lines": [
        {
          "speaker": "A",
          "zh": "你上午做什么？",
          "pinyin": "Nǐ shàngwǔ zuò shénme?",
          "kr": "오전에 뭐 해요?",
          "text": "你上午做什么？",
          "translation": {
            "kr": "오전에 뭐 해요?",
            "en": "What do you do in the morning?",
            "jp": "午前中は何をしますか？"
          }
        },
        {
          "speaker": "B",
          "zh": "我学习。",
          "pinyin": "Wǒ xuéxí.",
          "kr": "저는 공부해요.",
          "text": "我学习。",
          "translation": {
            "kr": "저는 공부해요.",
            "en": "I study.",
            "jp": "勉強します。"
          }
        }
      ]
    }
