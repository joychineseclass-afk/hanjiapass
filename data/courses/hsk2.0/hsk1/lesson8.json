  "grammar": [
    {
      "title": "点 + 分钟",
      "explanation_zh": "「点」表示钟点，「分钟」表示分。",
      "explanation_kr": "'点'는 시, '分钟'는 분을 나타냅니다.",
      "explanation_en": "点 for o'clock, 分钟 for minutes.",
      "example": {
        "zh": "九点十分",
        "pinyin": "jiǔ diǎn shí fēn",
        "kr": "9시 10분",
        "en": "9:10"
      },
      "explain": {
        "en": "点 for o'clock, 分钟 for minutes.",
        "kr": "'点'는 시, '分钟'는 분을 나타냅니다.",
        "zh": "「点」表示钟点，「分钟」表示分。"
      }
    },
    {
      "title": "上午 / 下午 / 中午",
      "explanation_zh": "时段词放在时间前。",
      "explanation_kr": "시간대는 시간 앞에 옵니다.",
      "explanation_en": "Time period before the time.",
      "example": {
        "zh": "下午三点",
        "pinyin": "xiàwǔ sān diǎn",
        "kr": "오후 3시",
        "en": "3 p.m."
      },
      "explain": {
        "en": "Time period before the time.",
        "kr": "시간대는 시간 앞에 옵니다.",
        "zh": "时段词放在时间前。"
      }
    }
  ],
