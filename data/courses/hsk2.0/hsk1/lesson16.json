  "grammar": [
    {
      "title": "来 / 去 / 回",
      "explanation_zh": "「来」向说话人，「去」离开，「回」返回。",
      "explanation_kr": "'来'는 말하는 사람 쪽으로, '去'는 떠남, '回'는 돌아감.",
      "explanation_en": "来 toward speaker, 去 away, 回 return.",
      "example": {
        "zh": "来学校，回家",
        "pinyin": "lái xuéxiào, huí jiā",
        "kr": "학교 오다, 집 돌아가다",
        "en": "come to school, go home"
      },
      "explain": {
        "jp": "「来」は話者へ、「去」は離れる、「回」は帰る。",
        "en": "来 toward speaker, 去 away, 回 return.",
        "kr": "'来'는 말하는 사람 쪽으로, '去'는 떠남, '回'는 돌아감.",
        "zh": "「来」向说话人，「去」离开，「回」返回。"
      }
    },
    {
      "title": "有",
      "explanation_zh": "「有」表示拥有。",
      "explanation_kr": "'有'는 소유를 나타냅니다.",
      "explanation_en": "有 indicates possession.",
      "example": {
        "zh": "我有书。",
        "pinyin": "Wǒ yǒu shū.",
        "kr": "저는 책이 있어요.",
        "en": "I have a book."
      },
      "explain": {
        "jp": "「有」は所有を表します。",
        "en": "有 indicates possession.",
        "kr": "'有'는 소유를 나타냅니다.",
        "zh": "「有」表示拥有。"
      }
    }
  ],
