  "scene": {
    "id": "l16_scene",
    "title": {
      "zh": "问去向与是否现在去",
      "kr": "어디 가는지, 지금 가는지",
      "en": "Where someone is going and when"
    },
    "summary": {
      "zh": "问「你去哪儿？」「你现在去吗？」，说去学校与回家时间。",
      "kr": "「你去哪儿？」「你现在去吗？」를 묻고 학교·귀가 시간을 말한다.",
      "en": "Ask where someone is going and when they go home."
    }
  },
  "objectives": [
    {
      "zh": "学会用「你去哪儿？」问去向",
      "kr": "「你去哪儿？」로 어디 가는지 물을 수 있다",
      "en": "Can ask where someone is going with 你去哪儿？"
    },
    {
      "zh": "学会用「什么时候回家」谈回家的时间",
      "kr": "「什么时候回家」로 언제 집에 가는지 말할 수 있다",
      "en": "Can talk about when to go home using 什么时候回家"
    }
  ],
  "vocab": [],
  "dialogue": [
    {
      "speaker": "A",
      "text": "你去哪儿？",
