  "grammar": [
    { "title": "来 / 去 / 回", "explanation_zh": "「来」向说话人，「去」离开，「回」返回。", "explanation_kr": "'来'는 말하는 사람 쪽으로, '去'는 떠남, '回'는 돌아감.", "explanation_en": "来 toward speaker, 去 away, 回 return.", "example": { "zh": "来学校，回家", "pinyin": "lái xuéxiào, huí jiā", "kr": "학교 오다, 집 돌아가다", "en": "come to school, go home" } },
