  "grammar": [
    {
      "pattern": "去哪儿 / 去 + 地点",
      "pinyin": "qù nǎr / qù + dìdiǎn",
      "explain": {
        "zh": "问去向用「你去哪儿？」。回答：我去+地点。",
        "kr": "어디 가는지 물을 때 「你去哪儿?」. 답: 我去+장소.",
        "en": "Ask where (someone) is going: 你去哪儿? Answer: 我去 + place.",
        "jp": "どこへ行くか「你去哪儿？」。答は「我去+場所」。"
      },
      "example": {
        "zh": "你去哪儿？我去学校。你现在去吗？对，我现在去。",
        "pinyin": "Nǐ qù nǎr? Wǒ qù xuéxiào. Nǐ xiànzài qù ma? Duì, wǒ xiànzài qù.",
        "translation": { "kr": "어디 가? 학교 가. 지금 가? 응, 지금 가.", "jp": "どこへ行く？学校へ。今行く？うん、今行く。", "en": "Where are you going? To school. Now? Yes, now." }
      }
    },
    {
      "pattern": "什么时候 + 动词",
      "pinyin": "shénme shíhou + dòngcí",
      "explain": {
        "zh": "「什么时候」问时间。什么时候回家？回答：我+时间+回家。",
        "kr": "「什么时候」는 \"언제\". 什么时候回家？我下午回家.",
        "en": "什么时候 = when. 什么时候回家？= When do you go home?",
        "jp": "「什么时候」はいつ。什么时候回家？我下午回家。"
      },
      "example": {
        "zh": "你什么时候回家？我下午回家。",
        "pinyin": "Nǐ shénme shíhou huí jiā? Wǒ xiàwǔ huí jiā.",
        "translation": { "kr": "언제 집에 가? 나는 오후에 가.", "jp": "いつ帰る？午後に帰る。", "en": "When do you go home? I go home in the afternoon." }
      }
    }
  ],
