  "dialogueCards": [
    {
      "title": { "zh": "会话1", "kr": "회화1", "en": "Session 1", "jp": "会話1" },
      "lines": [
        { "speaker": "A", "zh": "你在哪儿学习？", "pinyin": "Nǐ zài nǎr xuéxí?", "kr": "어디서 공부해요?", "text": "你在哪儿学习？", "translation": { "kr": "어디서 공부해요?", "en": "Where do you study?", "jp": "どこで勉強しますか？" } },
        { "speaker": "B", "zh": "我在学校学习汉语。", "pinyin": "Wǒ zài xuéxiào xuéxí Hànyǔ.", "kr": "저는 학교에서 중국어 공부해요.", "text": "我在学校学习汉语。", "translation": { "kr": "저는 학교에서 중국어 공부해요.", "en": "I study Chinese at school.", "jp": "学校で中国語を勉強します。" } }
      ]
    },
    {
      "title": { "zh": "会话2", "kr": "회화2", "en": "Session 2", "jp": "会話2" },
      "lines": [
        { "speaker": "A", "zh": "你读什么书？", "pinyin": "Nǐ dú shénme shū?", "kr": "무슨 책 읽어요?", "text": "你读什么书？", "translation": { "kr": "무슨 책 읽어요?", "en": "What book do you read?", "jp": "どんな本を読みますか？" } },
        { "speaker": "B", "zh": "我读汉语书。我有三本书。", "pinyin": "Wǒ dú Hànyǔ shū. Wǒ yǒu sān běn shū.", "kr": "중국어 책 읽어요. 책 세 권 있어요.", "text": "我读汉语书。我有三本书。", "translation": { "kr": "중국어 책 읽어요. 책 세 권 있어요.", "en": "I read Chinese books. I have three books.", "jp": "中国語の本を読みます。本が3冊あります。" } }
      ]
    },
    {
      "title": { "zh": "会话3", "kr": "회화3", "en": "Session 3", "jp": "会話3" },
      "lines": [
        { "speaker": "A", "zh": "你写字吗？", "pinyin": "Nǐ xiě zì ma?", "kr": "글자 써요?", "text": "你写字吗？", "translation": { "kr": "글자 써요?", "en": "Do you write characters?", "jp": "字を書きますか？" } },
        { "speaker": "B", "zh": "写，我写汉字。", "pinyin": "Xiě, wǒ xiě Hànzì.", "kr": "써요, 한자 써요.", "text": "写，我写汉字。", "translation": { "kr": "써요, 한자 써요.", "en": "Yes, I write Chinese characters.", "jp": "はい、漢字を書きます。" } }
      ]
    }
  ],
