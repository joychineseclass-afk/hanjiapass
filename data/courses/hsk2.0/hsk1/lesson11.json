  "grammar": [
    {
      "pattern": "今天星期几",
      "pinyin": "jīntiān xīngqī jǐ",
      "explain": {
        "zh": "问星期用「今天星期几？」。回答：今天+星期+数字（一、二…日/天）。",
        "kr": "요일을 물을 때 「今天星期几?」. 답: 今天+星期+숫자.",
        "en": "Ask day of week: 今天星期几? Answer: 今天 + 星期 + number.",
        "jp": "曜日は「今天星期几？」。答は「今天+星期+数字」。"
      },
      "example": {
        "zh": "今天星期几？今天星期三。",
        "pinyin": "Jīntiān xīngqī jǐ? Jīntiān xīngqī sān.",
        "translation": { "kr": "오늘 무슨 요일이야? 오늘 수요일이야.", "jp": "今日は何曜日？水曜日です。", "en": "What day is it? Wednesday." }
      }
    },
    {
      "pattern": "有 / 没有",
      "pinyin": "yǒu / méi yǒu",
      "explain": {
        "zh": "「有」表示拥有或存在；否定用「没有」。有课 = 有课，没有课 = 没课。",
        "kr": "「有」는 소유·존재. 부정은 「没有」. 有课/没有课.",
        "en": "有 = have / there is. Negative: 没有. 有课 / 没有课.",
        "jp": "「有」は持つ・ある。否定は「没有」。有课/没有课。"
      },
      "example": {
        "zh": "你今天有课吗？有，我下午有汉语课。你明天有课吗？没有，我明天没有课。",
        "pinyin": "Nǐ jīntiān yǒu kè ma? Yǒu, wǒ xiàwǔ yǒu Hànyǔ kè. Nǐ míngtiān yǒu kè ma? Méi yǒu, wǒ míngtiān méi yǒu kè.",
        "translation": { "kr": "오늘 수업 있어? 있어, 오후에 중국어 수업 있어. 내일 수업 있어? 없어.", "jp": "今日授業ある？ある。午後中国語の授業がある。明日ある？ない。", "en": "Do you have class today? Yes, Chinese in the afternoon. Tomorrow? No." }
      }
    }
  ],
