  ],
  "grammar": [
    { "title": "这 / 那", "explanation_zh": "「这」指近处，「那」指远处。", "explanation_kr": "'这'는 가까운 것, '那'는 먼 것.", "explanation_en": "这 for near, 那 for far.", "example": { "zh": "这个，那个", "pinyin": "zhè gè, nà gè", "kr": "이것, 저것", "en": "this one, that one" } },
    { "title": "呢", "explanation_zh": "「呢」用于追问或话题转换。", "explanation_kr": "'呢'는 재질문이나 화제 전환에 사용합니다.", "explanation_en": "呢 for follow-up or topic shift.", "example": { "zh": "那个呢？", "pinyin": "Nà gè ne?", "kr": "저것은요?", "en": "What about that one?" } }
