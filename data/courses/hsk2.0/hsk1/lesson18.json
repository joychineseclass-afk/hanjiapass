  "grammar": [
    {
      "pattern": "来 / 回来",
      "pinyin": "lái / huílái",
      "explain": {
        "zh": "「来」表示到说话人这边；「回来」表示从别处回到原处。王老师今天来学校吗？他什么时候回来？",
        "kr": "「来」는 말하는 쪽으로 오다. 「回来」는 돌아오다. 来学校吗？什么时候回来？",
        "en": "来 = come (here). 回来 = come back. 来学校吗？什么时候回来？",
        "jp": "「来」は話者へ来る。「回来」は帰ってくる。来学校吗？什么时候回来？"
      },
      "example": {
        "zh": "王老师今天来学校吗？今天不来，他去北京了。他什么时候回来？星期五回来。",
        "pinyin": "Wáng lǎoshī jīntiān lái xuéxiào ma? Jīntiān bù lái, tā qù Běijīng le. Tā shénme shíhou huílái? Xīngqī wǔ huílái.",
        "translation": { "kr": "왕 선생님 오늘 학교 와? 오늘 안 와, 베이징 갔어. 언제 돌아와? 금요일에.", "jp": "王老师は今日学校に来る？来ない。北京に行った。いつ戻る？金曜日に。", "en": "Is Teacher Wang coming today? No, he went to Beijing. When is he back? Friday." }
      }
    },
    {
      "pattern": "有 + 名词（电话） / 写给 + 人（给）",
      "pinyin": "yǒu + míngcí / xiě gěi + rén",
      "explain": {
        "zh": "「有」表示拥有：有电话。「给」表示给谁：写给你。你有王老师的电话吗？我写给你。",
        "kr": "「有」는 가지고 있다. 「给」는 누구에게 주는지. 你有电话吗？我写给你.",
        "en": "有 shows possession: 有电话. 给 shows giving to someone: 写给你。",
        "jp": "「有」は持つ、「给」は〜に与える。你有电话吗？我写给你。"
      },
      "example": {
        "zh": "你有王老师的电话吗？我写给你。",
        "pinyin": "Nǐ yǒu Wáng lǎoshī de diànhuà ma? Wǒ xiě gěi nǐ.",
        "translation": { "kr": "왕 선생님 전화번호 있어? 적어서 줄게.", "jp": "王先生の電話番号ある？書いてあげる。", "en": "Do you have Teacher Wang's number? I'll write it for you." }
      }
    }
  ],
