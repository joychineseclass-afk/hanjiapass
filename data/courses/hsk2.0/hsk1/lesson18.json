  "title": {
    "zh": "王老师今天来学校吗？",
    "pinyin": "Wáng lǎoshī jīntiān lái xuéxiào ma",
    "kr": "왕 선생님 오늘 학교에 와요?",
    "en": "Is Teacher Wang coming to school today?",
    "jp": "王先生は今日学校に来ますか？"
  },
  "summary": {
    "zh": "说来学校、什么时候回来和给电话",
    "kr": "학교에 오는지, 언제 돌아오는지, 전화번호를 주고받기",
    "en": "Talking about coming to school, returning time and giving a phone number"
  },
  "objectives": [
    {
      "zh": "学会用「来」「回来」说来学校和回来的时间",
      "kr": "「来」「回来」로 학교에 오는지와 돌아오는 시간을 말할 수 있다",
      "en": "Can use 来 and 回来 to talk about coming to school and returning"
    },
    {
      "zh": "学会用「有+电话」「写给你」给出联系方式",
      "kr": "「有+电话」「写给你」로 연락처를 줄 수 있다",
      "en": "Can use 有 + 电话 and 写给你 to give contact information"
    }
  ],
