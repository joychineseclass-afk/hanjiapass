      },
      "lines": [
        {
          "speaker": "A",
          "text": "书在哪儿？",
          "translation": {
            "en": "Where is the book?",
            "kr": "Where is the book?",
            "jp": "Where is the book?"
          },
          "pinyin": "shū zài nǎ ér ？"
        },
        {
          "speaker": "B",
          "text": "书在这里。",
          "translation": {
            "en": "The book is here.",
            "kr": "The book is here.",
            "jp": "The book is here."
          },
          "pinyin": "shū zài zhè lǐ 。"
        },
        {
          "speaker": "A",
          "text": "你在学校吗？",
          "translation": {
            "en": "Are you at school?",
            "kr": "Are you at school?",
            "jp": "Are you at school?"
          },
          "pinyin": "nǐ zài xué xiào ma ？"
        },
        {
          "speaker": "B",
          "text": "是，我在学校。他在那里。",
          "translation": {
            "en": "Yes, I'm at school. He's over there.",
            "kr": "Yes, I'm at school. He's over there.",
            "jp": "Yes, I'm at school. He's over there."
          },
          "pinyin": "shì ， wǒ zài xué xiào 。 tā zài nà lǐ 。"
        }
      ]
    }
  ],
  "grammar": [
    {
      "title": "做 + 工作",
      "explanation_zh": "「做」表示从事。",
      "explanation_kr": "'做'는 ~을 한다는 뜻입니다.",
      "explanation_en": "做 indicates doing work.",
      "example": {
        "zh": "做什么工作",
        "pinyin": "zuò shénme gōngzuò",
        "kr": "무슨 일 하다",
        "en": "what work do you do"
      },
      "explain": {
        "jp": "「做」は仕事をすることを表します。",
        "en": "做 indicates doing work.",
        "kr": "'做'는 ~을 한다는 뜻입니다.",
        "zh": "「做」表示从事。"
      }
    },
    {
      "title": "能 / 会",
      "explanation_zh": "「能」表示能力，「会」表示会做。",
      "explanation_kr": "'能'은 능력, '会'는 할 줄 알다.",
      "explanation_en": "能 for ability, 会 for knowing how.",
      "example": {
        "zh": "我能去。我会说汉语。",
        "pinyin": "Wǒ néng qù. Wǒ huì shuō Hànyǔ.",
        "kr": "저는 갈 수 있어요. 중국어를 할 줄 알아요.",
        "en": "I can go. I can speak Chinese."
      },
      "explain": {
        "jp": "「能」は能力、「会」は〜できることを表します。",
        "en": "能 for ability, 会 for knowing how.",
        "kr": "'能'은 능력, '会'는 할 줄 알다.",
        "zh": "「能」表示能力，「会」表示会做。"
      }
    }
  ],
