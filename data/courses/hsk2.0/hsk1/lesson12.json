  ],
  "dialogueCards": [],
  "grammar": [
    {
      "pattern": "喜欢 + 动词（听/看）",
      "pinyin": "xǐhuan + dòngcí",
      "explain": {
        "zh": "「喜欢」后接动词或动词短语，表示喜欢做某事。喜欢听音乐、喜欢看电影。",
        "kr": "「喜欢」 뒤에 동사(구)가 오면 ~하는 걸 좋아하다. 喜欢听音乐.",
        "en": "喜欢 + verb (phrase) = like to do. 喜欢听音乐, 喜欢看电影.",
        "jp": "「喜欢」の後に動詞が来ると、〜するのが好き。喜欢听音乐。"
      },
      "example": {
        "zh": "你喜欢听音乐吗？喜欢，我很喜欢听音乐。你喜欢看电影吗？喜欢，我也喜欢看电影。",
        "pinyin": "Nǐ xǐhuan tīng yīnyuè ma? Xǐhuan, wǒ hěn xǐhuan tīng yīnyuè. Nǐ xǐhuan kàn diànyǐng ma? Xǐhuan, wǒ yě xǐhuan kàn diànyǐng.",
        "translation": { "kr": "음악 듣는 거 좋아해? 응, 나 음악 듣는 거 너무 좋아해. 영화 보는 거 좋아해? 나도 좋아해.", "jp": "音楽を聞くのが好き？好き。映画を見るのが好き？私も好き。", "en": "Do you like listening to music? Yes, I do. Do you like watching movies? I do too." }
      }
    },
    {
      "pattern": "很 / 也",
      "pinyin": "hěn / yě",
      "explain": {
        "zh": "「很」放在形容词或心理动词前表程度；「也」表示“同样”。",
        "kr": "「很」는 형용사·심리동사 앞에서 정도. 「也」는 ~도.",
        "en": "很 = very (before adj/verb). 也 = also.",
        "jp": "「很」は程度。「也」は〜も。"
      },
      "example": {
        "zh": "我很喜欢听音乐。我也喜欢看电影。",
        "pinyin": "Wǒ hěn xǐhuan tīng yīnyuè. Wǒ yě xǐhuan kàn diànyǐng.",
        "translation": { "kr": "나는 음악 듣는 거 너무 좋아해. 나도 영화 보는 거 좋아해.", "jp": "音楽をとても好き。映画も好き。", "en": "I really like music. I also like movies." }
      }
    }
  ],
