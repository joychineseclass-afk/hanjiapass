  "grammar": [
    {
      "pattern": "你叫什么名字？",
      "pinyin": "nǐ jiào shénme míngzi",
      "explain": {
        "zh": "问对方的名字用「你叫什么名字？」。回答用「我叫+名字」。",
        "kr": "이름을 물을 때 「你叫什么名字？」. 답은 「我叫+이름」.",
        "en": "Ask names with 你叫什么名字? Answer with 我叫 + name.",
        "jp": "名前を聞くとき「你叫什么名字？」。答は「我叫+名前」。"
      },
      "example": {
        "zh": "你叫什么名字？我叫李明。",
        "pinyin": "Nǐ jiào shénme míngzi? Wǒ jiào Lǐ Míng.",
        "translation": { "kr": "이름이 뭐야? 나는 이명이야.", "jp": "お名前は？李明です。", "en": "What's your name? I'm Li Ming." }
      }
    },
    {
      "pattern": "呢（追问）",
      "pinyin": "ne",
      "explain": {
        "zh": "「呢」用在句末，表示追问对方同样的问题。如：你呢？= 你叫什么名字呢？",
        "kr": "「呢」는 문장 끝에 써서 상대에게 같은 걸 묻습니다. 예: 你呢？",
        "en": "呢 at the end asks the same question to the other. 你呢？= And you?",
        "jp": "「呢」は文末で相手に同じことを聞く。「你呢？」＝あなたは？"
      },
      "example": {
        "zh": "你呢？",
        "pinyin": "Nǐ ne?",
        "translation": { "kr": "너는?", "jp": "あなたは？", "en": "And you?" }
      }
    }
  ],
