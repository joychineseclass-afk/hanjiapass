      },
      "lines": [
        {
          "speaker": "A",
          "text": "你是学生吗？",
          "pinyin": "Nǐ shì xuéshēng ma?",
          "translation": {
            "kr": "학생이에요?",
            "en": "Are you a student?",
            "jp": "学生ですか？"
          }
        },
        {
          "speaker": "B",
          "text": "是。我住在北京，在中国。他是我的朋友，也是我同学。",
          "pinyin": "Shì. Wǒ zhù zài Běijīng, zài Zhōngguó. Tā shì wǒ péngyou, yě shì wǒ tóngxué.",
          "translation": {
            "kr": "네. 베이징에 살아요, 중국에요. 그는 제 친구이고 동창이에요.",
            "en": "Yes. I live in Beijing, in China. He is my friend and also my classmate.",
            "jp": "はい。北京に住んでいます、中国です。彼は私の友達で、クラスメートでもあります。"
          }
        }
      ]
    }
