  "grammar": [
    {
      "title": "A 是 B",
      "explanation_zh": "「是」连接主语和宾语，表示等同。",
      "explanation_kr": "'是'는 주어와 목적어를 연결합니다.",
      "explanation_en": "是 connects subject and object.",
      "explanation_jp": "「是」は主語と目的語をつなぎ、同等であることを表します。",
      "example": {
        "zh": "他是老师。",
        "pinyin": "Tā shì lǎoshī.",
        "kr": "그는 선생님이에요.",
        "en": "He is a teacher.",
        "jp": "彼は先生です。"
      },
      "explain": {
        "jp": "「是」は主語と目的語をつなぎ、同等であることを表します。",
        "en": "是 connects subject and object.",
        "kr": "'是'는 주어와 목적어를 연결합니다.",
        "zh": "「是」连接主语和宾语，表示等同。"
      }
    },
    {
      "title": "不 + 是",
      "explanation_zh": "否定「是」用「不」。",
      "explanation_kr": "'是'의 부정은 '不'를 사용합니다.",
      "explanation_en": "Negate 是 with 不.",
      "explanation_jp": "「是」の否定には「不」を使います。",
      "example": {
        "zh": "他不是老师。",
        "pinyin": "Tā bú shì lǎoshī.",
        "kr": "그는 선생님이 아닙니다.",
        "en": "He is not a teacher.",
        "jp": "彼は先生ではありません。"
      },
      "explain": {
        "jp": "「是」の否定には「不」を使います。",
        "en": "Negate 是 with 不.",
        "kr": "'是'의 부정은 '不'를 사용합니다.",
        "zh": "否定「是」用「不」。"
      }
    }
