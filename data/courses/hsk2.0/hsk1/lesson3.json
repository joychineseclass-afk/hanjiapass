  "grammar": [
    {
      "title": "是 — 判断句",
      "explanation_zh": "\"是\"用于连接主语和身份、职业。",
      "explanation_kr": "'是'는 주어와 신분·직업을 연결합니다.",
      "explanation_en": "\"是\" connects the subject with identity or job.",
      "example": {
        "zh": "我是学生。",
        "pinyin": "Wǒ shì xuéshēng.",
        "kr": "저는 학생이에요.",
        "en": "I'm a student."
      }
    },
    {
      "title": "认识 — 认识新朋友",
      "explanation_zh": "\"认识\"表示认识某人。",
      "explanation_kr": "'认识'는 ~를 알다/만나다입니다.",
      "explanation_en": "\"认识\" means to know or meet someone.",
      "example": {
        "zh": "很高兴认识你！",
        "pinyin": "Hěn gāoxìng rènshi nǐ!",
        "kr": "만나서 반가워요!",
        "en": "Nice to meet you!"
      }
    }
  ],
