      "lines": [
        {
          "speaker": "A",
          "text": "你是哪国人？",
          "pinyin": "Nǐ shì nǎ guó rén?",
          "translation": {
            "kr": "어느 나라 사람이에요?",
            "en": "Which country are you from?",
            "jp": "どこの国の方ですか？"
          }
