        {
          "speaker": "B",
          "text": "我是中国人。",
          "pinyin": "Wǒ shì Zhōngguó rén.",
          "translation": {
            "kr": "저는 중국인이에요.",
            "en": "I'm Chinese.",
            "jp": "私は中国人です。"
          }
        }
      ]
    },
