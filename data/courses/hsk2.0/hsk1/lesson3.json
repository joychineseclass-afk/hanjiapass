  "grammar": [
    {
      "pattern": "是……（肯定）",
      "pinyin": "shì",
      "explanation": {
        "kr": "「是」는 긍정 판단. 구조: A 是 B. 국적 답: 我是+나라+人.",
        "en": "是 indicates affirmative. Pattern: A 是 B. Nationality: 我是 + country + 人.",
        "jp": "「是」は肯定判断。A 是 B。国籍の答え：我是+国+人。"
      },
      "example": {
        "text": "你是哪国人？",
        "pinyin": "Nǐ shì nǎ guó rén ？",
        "translation": {
          "kr": "어느 나라 사람이에요?",
          "en": "Which country are you from?",
          "jp": "どこの国の人ですか？"
        }
      }
    },
    {
      "pattern": "吗（一般疑问句）",
      "pinyin": "ma",
      "explanation": {
        "kr": "「吗」를 문장 끝에 붙이면 의문문이 됩니다. 답은 「是」或「不是」.",
        "en": "吗 at the end turns a statement into a yes/no question. Answer with 是 or 不是.",
        "jp": "「吗」を文末に付けると疑問文になります。答は「是」或「不是」。"
      },
      "example": {
        "text": "你是中国人吗？",
        "pinyin": "Nǐ shì zhōng guó rén ma ？",
        "translation": {
          "kr": "중국인이에요?",
          "en": "Are you Chinese?",
          "jp": "中国人ですか？"
        }
      }
    },
    {
      "pattern": "不是",
      "pinyin": "bú shì",
      "explanation": {
        "kr": "「不是」는 「是」의 부정. \"~가 아니다\".",
        "en": "不是 is the negative of 是. It means \"is not\".",
        "jp": "「不是」は「是」の否定。「〜ではない」。"
      },
      "example": {
        "text": "不是，我是韩国人。我是韩国人。",
        "pinyin": "Bú shì ， wǒ shì hán guó rén 。 Wǒ shì hán guó rén 。",
        "translation": {
          "kr": "아니요, 저는 한국인이에요. 저는 한국인이에요.",
          "en": "No, I'm Korean. I'm Korean.",
          "jp": "いいえ、韓国人です。 韓国人です。"
        }
      }
    }
  ],
