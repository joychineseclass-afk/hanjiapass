      "title": {
        "zh": "会话1",
        "kr": "회화1",
        "en": "Session 1",
        "jp": "会話1"
      },
      "lines": [
        {
          "speaker": "A",
          "text": "你有几个苹果？",
          "translation": {
            "en": "How many apples do you have?",
            "kr": "How many apples do you have?",
            "jp": "How many apples do you have?"
          },
          "pinyin": "nǐ yǒu jǐ gè píng guǒ ？"
        },
        {
          "speaker": "B",
          "text": "我有五个苹果。",
          "translation": {
            "en": "I have five apples.",
            "kr": "I have five apples.",
            "jp": "I have five apples."
          },
          "pinyin": "wǒ yǒu wǔ gè píng guǒ 。"
        },
        {
          "speaker": "A",
          "text": "我有三个。一、二、三。",
          "translation": {
            "en": "I have three. One, two, three.",
            "kr": "I have three. One, two, three.",
            "jp": "I have three. One, two, three."
          },
          "pinyin": "wǒ yǒu sān gè 。 yī 、 èr 、 sān 。"
        }
      ]
    },
    {
      "title": {
        "zh": "会话2",
        "kr": "회화2",
        "en": "Session 2",
        "jp": "会話2"
      },
      "lines": [
        {
          "speaker": "A",
          "text": "多少个？",
          "translation": {
            "en": "How many?",
            "kr": "How many?",
            "jp": "How many?"
          },
          "pinyin": "duō shǎo gè ？"
        },
        {
          "speaker": "B",
          "text": "六个。你要几个？",
          "translation": {
            "en": "Six. How many do you want?",
            "kr": "Six. How many do you want?",
            "jp": "Six. How many do you want?"
          },
          "pinyin": "liù gè 。 nǐ yào jǐ gè ？"
        },
        {
          "speaker": "A",
          "text": "我要两个。谢谢。",
          "translation": {
            "en": "I want two. Thanks.",
            "kr": "I want two. Thanks.",
            "jp": "I want two. Thanks."
          },
          "pinyin": "wǒ yào liǎng gè 。 xiè xiè 。"
        }
      ]
    }
  ],
