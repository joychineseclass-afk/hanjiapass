  "grammar": [
    {
      "title": "是 — 判断句（身份职业）",
      "explanation_zh": "用“是”连接主语和身份、职业。",
      "explanation_kr": "'是'는 주어와 직업·신분을 연결합니다.",
      "example": "他是医生。"
    },
    {
      "title": "吗 — 职业疑问句",
      "explanation_zh": "在判断句后加“吗”构成疑问句。",
      "explanation_kr": "판단문 뒤에 '吗'를 붙이면 의문문이 됩니다.",
      "example": "她是老师吗？"
    }
  ],
