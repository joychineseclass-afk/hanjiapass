  "grammar": [
    {
      "pattern": "做什么工作",
      "pinyin": "zuò shénme gōngzuò",
      "explain": {
        "zh": "问职业用「你做什么工作？」。回答：我是+职业（医生/老师…）。",
        "kr": "직업을 물을 때 「你做什么工作?」. 답: 我是+직업.",
        "en": "Ask job: 你做什么工作? Answer: 我是 + job (doctor, teacher...).",
        "jp": "職業は「你做什么工作？」。答は「我是+職業」。"
      },
      "example": {
        "zh": "你做什么工作？我是医生。",
        "pinyin": "Nǐ zuò shénme gōngzuò? Wǒ shì yīshēng.",
        "translation": { "kr": "무슨 일 해? 나는 의사야.", "jp": "お仕事は？医者です。", "en": "What do you do? I'm a doctor." }
      }
    },
    {
      "pattern": "在 + 地点 + 工作",
      "pinyin": "zài + dìdiǎn + gōngzuò",
      "explain": {
        "zh": "问工作地点：你在哪儿工作？回答：我在+地点+工作。",
        "kr": "어디서 일하는지: 你在哪儿工作? 답: 我在+장소+工作.",
        "en": "Where do you work? 你在哪儿工作？我在北京医院工作.",
        "jp": "どこで働くか「你在哪儿工作？」。答は「我在+場所+工作」。"
      },
      "example": {
        "zh": "你在哪儿工作？我在北京医院工作。他呢？他也是医生。",
        "pinyin": "Nǐ zài nǎr gōngzuò? Wǒ zài Běijīng yīyuàn gōngzuò. Tā ne? Tā yě shì yīshēng.",
        "translation": { "kr": "어디서 일해? 베이징 병원에서. 그는? 그도 의사야.", "jp": "どこで働いてる？北京病院で。彼は？彼も医者です。", "en": "Where do you work? At Beijing Hospital. And him? He's a doctor too." }
      }
    }
  ],
