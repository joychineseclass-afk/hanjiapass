      "title": { "zh": "会话2", "kr": "회화2", "en": "Session 2", "jp": "会話2" },
      "lines": [
        { "speaker": "A", "zh": "你去医院了吗？", "pinyin": "Nǐ qù yīyuàn le ma?", "kr": "병원 갔어요?", "text": "你去医院了吗？", "translation": { "kr": "병원 갔어요?", "en": "Did you go to the hospital?", "jp": "病院に行きましたか？" } },
