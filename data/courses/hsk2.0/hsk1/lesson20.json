      ]
    },
    {
      "title": { "zh": "会话3", "kr": "회화3", "en": "Session 3", "jp": "会話3" },
      "lines": [
        { "speaker": "A", "zh": "现在怎么样？我们去医院吧。你呢？", "pinyin": "Xiànzài zěnmeyàng? Wǒmen qù yīyuàn ba. Nǐ ne?", "kr": "지금 어때요? 우리 병원 가요. 당신은요?", "text": "现在怎么样？我们去医院吧。你呢？", "translation": { "kr": "지금 어때요? 우리 병원 가요. 당신은요?", "en": "How are you now? Let's go to the hospital. And you?", "jp": "今どうですか？病院に行きましょう。あなたは？" } },
