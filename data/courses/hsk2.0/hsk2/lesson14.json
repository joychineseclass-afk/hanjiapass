    {
      "speaker": "A",
      "cn": "我们一起去旅行吧！",
      "pinyin": "Wǒmen yīqǐ qù lǚxíng ba!",
      "translations": {
        "kr": "우리 함께 여행 가요!",
        "en": "Let's travel together!",
        "jp": "一緒に旅行に行きましょう！"
      }
    },
    {
      "speaker": "B",
      "cn": "去年我去过机场，今年买票去。",
      "pinyin": "Qùnián wǒ qùguò jīchǎng, jīnnián mǎi piào qù.",
      "translations": {
        "kr": "작년에 공항 갔어요. 올해 표 사서 가요.",
        "en": "Last year I went to the airport, this year I'll buy tickets.",
        "jp": "去年空港に行きました。今年は切符を買って行きます。"
      }
    }
  ],
