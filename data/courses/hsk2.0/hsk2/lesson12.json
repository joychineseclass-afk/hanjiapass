      "lines": [
        {
          "speaker": "A",
          "cn": "他工作很努力。",
          "pinyin": "Tā gōngzuò hěn nǔlì.",
          "translations": {
            "kr": "그는 일을 열심히 해요.",
            "en": "He works very hard.",
            "jp": "彼は一生懸命働きます。"
          }
        },
        {
          "speaker": "B",
          "cn": "但是很累，早上起床就送孩子。",
          "pinyin": "Dànshì hěn lěi, zǎoshang qǐchuáng jiù sòng háizi.",
          "translations": {
            "kr": "하지만 피곤해요. 아침에 일어나자마자 아이를 보내요.",
            "en": "But very tired, gets up and sends the child in the morning.",
            "jp": "しかし疲れています。朝起きてすぐ子供を送ります。"
          }
        }
      ]
    }
  ],
