  "grammar": [
    {
      "pattern": "您 / 你",
      "pinyin": "nín / nǐ",
      "hint": {
        "zh": "敬称 / 通称",
        "kr": "높임말 / 보통 말",
        "en": "polite / casual",
        "jp": "敬称 / 一般"
      },
      "explanation": {
        "zh": "（第二人称用法）「您」是敬称，多用于长辈、师长或不熟悉的人；「你」是一般第二人称，用于平辈或较随意的场合。对老师可说「您好」，同学之间常用「你好」。",
        "kr": "「您」은 높임말로 어른·스승·낯선 사람에게 자주 쓰입니다. 「你」는 일반적인 2인칭으로 또래나 편한 상황에 쓰입니다. 스승에게는 「您好」, 친구에게는 「你好」가 흔합니다.",
        "en": "您 is polite “you” (elders, teachers, strangers). 你 is neutral “you” (peers, informal contexts). 您好 addresses a teacher; 你好 is common among classmates.",
        "jp": "「您」は敬称（目上・先生・初対面など）。「你」は一般的な「あなた」（同輩・くだけた場面）。先生には「您好」、仲間には「你好」がよく使われます。"
      },
      "examples": [
        {
          "zh": "王老师，您好！",
          "pinyin": "Wáng lǎoshī, nín hǎo!",
          "translation": {
            "kr": "왕 선생님, 안녕하세요!",
            "en": "Hello, Teacher Wang!",
            "jp": "王先生、こんにちは！"
          }
        },
        {
          "zh": "你好，李明！",
          "pinyin": "Nǐ hǎo, Lǐ Míng!",
          "translation": {
            "kr": "안녕, 이명!",
            "en": "Hello, Li Ming!",
            "jp": "李明さん、こんにちは！"
          }
        }
      ]
    }
  ],
