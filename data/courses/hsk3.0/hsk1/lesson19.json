        {
          "speaker": "李明",
          "text": "有菜单吗？",
          "pinyin": "Yǒu càidān ma?",
          "translation": {
            "kr": "메뉴 있어요?",
            "en": "Do you have a menu?",
            "jp": "メニューはありますか。"
          }
        },
        {
          "speaker": "饭店",
          "text": "这是菜单。",
          "pinyin": "Zhè shì càidān.",
          "translation": {
            "kr": "여기 메뉴예요.",
            "en": "Here’s the menu.",
            "jp": "メニューです。"
          }
        },
        {
          "speaker": "李明",
          "text": "给我三个包子吧。",
          "pinyin": "Gěi wǒ sān ge bāozi ba.",
          "translation": {
