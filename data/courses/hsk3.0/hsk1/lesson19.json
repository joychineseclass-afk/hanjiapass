        {
          "speaker": "李明",
          "text": "一杯茶。",
          "pinyin": "Yì bēi chá.",
          "translation": {
            "kr": "차 한 잔이요.",
            "en": "A cup of tea.",
            "jp": "お茶一杯。"
          }
        },
        {
          "speaker": "饭店",
          "text": "好的。三个包子一杯茶",
          "pinyin": "Hǎo de. Sān ge bāozi yì bēi chá",
          "translation": {
            "kr": "알겠습니다. 만두 세 개, 차 한 잔.",
            "en": "Sure—three buns and a tea.",
            "jp": "はい。包子三つ、お茶一杯。"
