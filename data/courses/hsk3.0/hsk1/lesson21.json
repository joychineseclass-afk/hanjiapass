            "kr": "의사는 뭐래?",
            "en": "What did the doctor say?",
            "jp": "医者は何と？"
          }
        },
        {
          "speaker": "汤姆",
          "text": "医生说要多休息。",
          "pinyin": "Yīshēng shuō yào duō xiūxi.",
          "translation": {
            "kr": "푹 쉬래요.",
            "en": "Rest more.",
            "jp": "たくさん休むようにと。"
          }
        },
        {
          "speaker": "李明",
          "text": "你现在怎么样？",
          "pinyin": "Nǐ xiànzài zěnmeyàng?",
          "translation": {
            "kr": "지금 좀 어때?",
            "en": "How are you now?",
            "jp": "今どう？"
          }
        },
        {
          "speaker": "汤姆",
          "text": "好多了，医生说没事。",
          "pinyin": "Hǎo duō le, yīshēng shuō méishì.",
          "translation": {
            "kr": "많이 나았어요, 괜찮대요.",
            "en": "Much better—the doctor says it’s fine.",
            "jp": "だいぶよくなりました、大丈夫だそうです。"
          }
        }
      ]
    },
    {
      "title": {
        "zh": "会话三｜安慰病人",
        "kr": "회화 3｜위로",
        "en": "Dialogue 3 | Comfort",
        "jp": "会話3｜見舞い"
      },
      "summary": {
        "zh": "让多睡、说明天再来看、道别。",
        "kr": "잠·내일 다시·안녕.",
        "en": "Sleep—come back tomorrow—bye.",
        "jp": "寝る／明日また／さようなら。"
      },
      "lines": [
        {
          "speaker": "李明",
          "text": "汤姆，你睡一会吧。",
          "pinyin": "Tāngmǔ, nǐ shuì yīhuìr ba.",
          "translation": {
            "kr": "탐, 좀 자.",
            "en": "Tom—get some sleep.",
            "jp": "トム、ちょっと寝な。"
          }
        },
        {
          "speaker": "汤姆",
          "text": "我好多了。",
          "pinyin": "Wǒ hǎo duō le.",
          "translation": {
            "kr": "많이 나았어요.",
            "en": "I’m much better.",
            "jp": "だいぶよくなりました。"
          }
        },
        {
          "speaker": "李明",
          "text": "要好好休息。我明天再来看你。",
          "pinyin": "Yào hǎohāo xiūxi. Wǒ míngtiān zài lái kàn nǐ.",
