        "kr": "회화 1｜몸이 안 좋을 때",
        "en": "Dialogue 1 | Feeling ill",
        "jp": "会話1｜具合が悪い"
      },
      "summary": {
        "zh": "问怎么了，说生病了，提议一起去医院。",
        "kr": "어떻게 됐니·아픔·병원.",
        "en": "What’s wrong—ill—hospital.",
        "jp": "どうした／病気／病院。"
      },
      "lines": [
        {
          "speaker": "李明",
          "text": "汤姆，你怎么了？",
          "pinyin": "Tāngmǔ, nǐ zěnme le?",
          "translation": {
            "kr": "탐, 왜 그래?",
            "en": "Tom, what’s wrong?",
            "jp": "トム、どうしたの？"
          }
        },
        {
          "speaker": "汤姆",
          "text": "我生病了。",
          "pinyin": "Wǒ shēngbìng le.",
          "translation": {
            "kr": "아파요.",
            "en": "I’m sick.",
            "jp": "病気です。"
          }
        },
        {
          "speaker": "李明",
          "text": "去医院看病了吗？",
          "pinyin": "Qù yīyuàn kànbìng le ma?",
          "translation": {
            "kr": "병원 갔다 왔어?",
            "en": "Have you been to the hospital?",
            "jp": "病院に行った？"
          }
        },
        {
          "speaker": "汤姆",
          "text": "没有。",
          "pinyin": "Méiyǒu.",
          "translation": {
            "kr": "아니요.",
            "en": "No.",
            "jp": "いいえ。"
          }
        },
        {
          "speaker": "李明",
          "text": "我和你去医院吧。",
          "pinyin": "Wǒ hé nǐ qù yīyuàn ba.",
          "translation": {
            "kr": "같이 병원 가자.",
            "en": "Let’s go together.",
            "jp": "一緒に病院に行こう。"
          }
        },
        {
          "speaker": "汤姆",
          "text": "好的，谢谢。",
          "pinyin": "Hǎo de, xièxie.",
          "translation": {
            "kr": "네, 고마워요.",
            "en": "Okay—thanks.",
            "jp": "はい、ありがとう。"
          }
        }
      ]
    },
    {
      "title": {
        "zh": "会话二｜询问病情",
