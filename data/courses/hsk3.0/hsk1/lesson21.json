      "summary": {
        "zh": "问医生怎么说、现在怎么样，说好多了、没事。",
        "kr": "의사 말·괜찮음.",
        "en": "Doctor said—feeling better.",
        "jp": "先生の話／大丈夫。"
      },
      "lines": [
        {
          "speaker": "李明",
          "text": "医生怎么说？",
          "pinyin": "Yīshēng zěnme shuō?",
