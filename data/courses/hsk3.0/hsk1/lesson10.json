          "text": "十块。",
          "pinyin": "Shí kuài.",
          "translation": {
            "kr": "십 위안이에요.",
            "en": "Ten yuan.",
            "jp": "十元です。"
          }
        },
        {
          "speaker": "汤姆",
          "text": "那个呢？",
          "pinyin": "Nàge ne?",
          "translation": {
            "kr": "저건요?",
            "en": "What about that one?",
            "jp": "あれは？"
          }
        },
        {
          "speaker": "店员",
          "text": "那个十二块。",
          "pinyin": "Nàge shí’èr kuài.",
          "translation": {
            "kr": "저건 십이 위안이에요.",
            "en": "That one is twelve yuan.",
            "jp": "あれは十二元です。"
          }
        }
      ]
    },
