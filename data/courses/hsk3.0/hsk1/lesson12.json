      "summary": {
        "zh": "问房间大不大，请求看一看，称赞房间好看。",
        "kr": "방이 큰지 묻고 볼 수 있게 부탁한 뒤 예쁘다고 말합니다.",
        "en": "They ask if the room is big, ask to look, and say it looks nice.",
        "jp": "広いか聞き、見せてもらい、きれいだと言います。"
      },
      "lines": [
        {
          "speaker": "王美",
          "text": "你的房间大不大？",
          "pinyin": "Nǐ de fángjiān dà bù dà?",
          "translation": {
            "kr": "방이 큰 편이에요?",
            "en": "Is your room big?",
            "jp": "お部屋は広いですか。"
          }
        },
        {
          "speaker": "汤姆",
          "text": "不大，有一点儿小。",
          "pinyin": "Bù dà, yǒu yìdiǎnr xiǎo.",
          "translation": {
            "kr": "크진 않아요, 좀 작아요.",
            "en": "Not really—it’s a bit small.",
            "jp": "大きくはなくて、ちょっと狭いです。"
          }
        },
        {
          "speaker": "王美",
          "text": "我能看看吗？",
          "pinyin": "Wǒ néng kànkan ma?",
          "translation": {
            "kr": "좀 봐도 될까요?",
            "en": "Can I take a look?",
            "jp": "ちょっと見てもいいですか。"
          }
        },
        {
          "speaker": "汤姆",
          "text": "可以。",
          "pinyin": "Kěyǐ.",
          "translation": {
            "kr": "네, 괜찮아요.",
            "en": "Sure.",
            "jp": "いいですよ。"
          }
        },
        {
          "speaker": "王美",
          "text": "房间真好看！",
          "pinyin": "Fángjiān zhēn hǎokàn!",
          "translation": {
            "kr": "방이 정말 예뻐요!",
            "en": "Your room looks great!",
            "jp": "お部屋、すてきですね！"
          }
        },
        {
          "speaker": "汤姆",
          "text": "谢谢。",
          "pinyin": "Xièxie.",
          "translation": {
            "kr": "감사해요.",
            "en": "Thanks.",
            "jp": "ありがとう。"
          }
        }
      ]
    },
