  "title": {
    "zh": "第12课｜房间里有什么？",
    "cn": "第12课｜房间里有什么？",
    "kr": "제12과｜방 안에 뭐가 있어요?",
    "en": "Lesson 12 | What’s in the Room?",
    "jp": "第12課｜部屋の中に何がありますか。"
  },
  "summary": {
    "zh": "学习用「……里有什么」描述房间与处所里的事物，用「能/可以」表许可，用形容词作谓语描述大小、新旧与好看。",
    "kr": "「…里有什么」로 방·장소 안을 말하고 「能／可以」로 허락을, 형용사 서술로 크기·새것·예쁨을 말합니다.",
    "en": "Say what’s in a room with …里有什么; use 能/可以 for permission; adjectives for size, newness, 好看.",
    "jp": "「…里有什么」で中身、「能／可以」で許可、形容詞述語で大きさや見た目を言います。"
  },
  "scene": {
    "id": "hsk30_l12_scene",
    "title": {
      "zh": "房间与里外",
      "kr": "방 안과 밖",
      "en": "Inside & outside",
      "jp": "部屋の内外"
    },
    "summary": {
      "zh": "会话一：房间大小与参观；会话二：房间里和外边有什么；会话三：书与书包的位置。",
      "kr": "회화1 방 크기·구경 → 회화2 안·밖에 뭐가 → 회화3 책·가방 위치.",
      "en": "1: Room size & looking around · 2: What’s inside/outside · 3: Where book & bag are.",
      "jp": "会話1 広さ／会話2 中と外／会話3 位置。"
    }
  },
  "objectives": [
    {
      "zh": "能用「房间里有什么？」「外边有……」描述处所里或外的事物",
      "pinyin": "fángjiān lǐ · wàibian yǒu",
      "kr": "방 안·밖에 무엇이 있는지 말한다.",
      "en": "Say what’s in the room or outside with 有.",
      "jp": "「房间里」「外边」に何があるか言える。"
    },
    {
      "zh": "能用「能……吗？」「可以」表达请求许可，用「大不大」「真好看」等描述房间",
      "pinyin": "néng · kěyǐ · zhēn hǎokàn",
      "kr": "「能…吗?」「可以」로 허락을 묻고, 「大不大」「真好看」로 방을 묘사한다.",
      "en": "Ask 能…吗?, hear 可以; describe rooms with 大不大, 真好看.",
      "jp": "「能」「可以」で許可、「大不大」「真好看」で描写。"
    }
  ],
