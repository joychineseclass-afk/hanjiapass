          "text": "公司里忙吗？",
          "pinyin": "Gōngsī lǐ máng ma?",
          "translation": {
            "kr": "회사 바빠요?",
            "en": "Is it busy there?",
            "jp": "会社は忙しい？"
          }
        },
        {
          "speaker": "安娜",
          "text": "很忙。",
          "pinyin": "Hěn máng.",
          "translation": {
            "kr": "많이 바빠요.",
            "en": "Very busy.",
            "jp": "とても忙しいです。"
          }
        },
        {
          "speaker": "王美",
          "text": "你喜欢现在的工作吗？",
          "pinyin": "Nǐ xǐhuan xiànzài de gōngzuò ma?",
          "translation": {
            "kr": "지금 일 좋아해요?",
            "en": "Do you like your job?",
            "jp": "今の仕事は好き？"
          }
        },
        {
          "speaker": "安娜",
          "text": "不太喜欢，太忙了。",
          "pinyin": "Bú tài xǐhuan, tài máng le.",
          "translation": {
            "kr": "별로예요, 너무 바빠서요.",
            "en": "Not really—it’s too busy.",
            "jp": "あまり好きじゃないです、忙しすぎて。"
          }
        }
      ]
    },
    {
      "title": {
        "zh": "会话三｜认识同事",
        "kr": "회화 3｜동료",
        "en": "Dialogue 3 | Colleagues",
        "jp": "会話3｜同僚"
      },
      "summary": {
        "zh": "在公司问候新人，问认不认识说话的先生，是不是男朋友，说是大学同学、只是朋友。",
        "kr": "신입·아는 사이·남자 친구 아님.",
        "en": "New colleague—know that man—not dating.",
        "jp": "新人／知り合い／友だち。"
      },
      "lines": [
        {
          "speaker": "李明",
          "text": "女士，你好，你是新来公司的吗？",
          "pinyin": "Nǚshì, nǐ hǎo, nǐ shì xīn lái gōngsī de ma?",
          "translation": {
            "kr": "안녕하세요, 신입이세요?",
            "en": "Hello—are you new here?",
            "jp": "こんにちは、新しく入られた方ですか。"
          }
        },
        {
          "speaker": "安娜",
          "text": "是的，我是新来的。",
          "pinyin": "Shì de, wǒ shì xīn lái de.",
          "translation": {
            "kr": "네, 신입이에요.",
            "en": "Yes—I’m new.",
            "jp": "はい、新人です。"
          }
        },
        {
          "speaker": "李明",
          "text": "你认识和你说话的先生吗？",
          "pinyin": "Nǐ rènshi hé nǐ shuōhuà de xiānsheng ma?",
          "translation": {
            "kr": "아까 말씀하신 남자 분 아세요?",
            "en": "Do you know the gentleman you were talking to?",
            "jp": "お話ししていた男性を知っていますか。"
          }
        },
        {
          "speaker": "安娜",
          "text": "认识，他是我的大学同学。",
          "pinyin": "Rènshi, tā shì wǒ de dàxué tóngxué.",
          "translation": {
            "kr": "알아요, 대학 동기예요.",
            "en": "Yes—he’s a college classmate.",
            "jp": "ええ、大学の同学です。"
          }
        },
        {
          "speaker": "李明",
          "text": "他是你男朋友吗？",
          "pinyin": "Tā shì nǐ nánpéngyou ma?",
