  "dialogueCards": [
    {
      "title": {
        "zh": "会话一｜在中国工作",
        "kr": "회화 1｜중국에서 일",
        "en": "Dialogue 1 | Working in China",
        "jp": "会話1｜中国で働く"
      },
      "summary": {
        "zh": "什么时候来中国、第几年、上班与学汉语、想家与父母明年来看。",
        "kr": "언제·몇 년째·일정·가족.",
        "en": "When—year count—schedule—family.",
        "jp": "いつ・何年目・予定・家族。"
      },
      "lines": [
        {
          "speaker": "李明",
          "text": "安娜，你什么时候来中国的？",
          "pinyin": "Ānnà, nǐ shénme shíhou lái Zhōngguó de?",
          "translation": {
            "kr": "안나, 언제 중국 왔어?",
            "en": "Anna, when did you come to China?",
            "jp": "アンナさん、いつ中国に来ましたか。"
          }
        },
        {
          "speaker": "安娜",
          "text": "我去年来的。现在是第二年。",
          "pinyin": "Wǒ qùnián lái de. Xiànzài shì dì èr nián.",
          "translation": {
            "kr": "작년에 왔어요. 지금 2년째예요.",
            "en": "Last year—this is my second year.",
            "jp": "去年来ました。今が二年目です。"
          }
        },
        {
          "speaker": "李明",
          "text": "你在中国工作吗？",
          "pinyin": "Nǐ zài Zhōngguó gōngzuò ma?",
          "translation": {
            "kr": "중국에서 일해요?",
            "en": "Do you work in China?",
            "jp": "中国でお仕事を？"
          }
        },
        {
          "speaker": "安娜",
          "text": "是的，我星期一到星期六工作。",
          "pinyin": "Shì de, wǒ Xīngqī yī dào Xīngqīliù gōngzuò.",
          "translation": {
            "kr": "네, 월~토에 일해요.",
            "en": "Yes—Monday through Saturday.",
            "jp": "ええ、月曜から土曜まで働いています。"
          }
        },
        {
          "speaker": "李明",
          "text": "星期天呢？",
          "pinyin": "Xīngqītiān ne?",
          "translation": {
            "kr": "일요일은?",
            "en": "And Sunday?",
            "jp": "日曜は？"
          }
        },
        {
          "speaker": "安娜",
          "text": "星期天去学校学习汉语。",
          "pinyin": "Xīngqītiān qù xuéxiào xuéxí Hànyǔ.",
          "translation": {
            "kr": "일요일엔 학교 가서 중국어 공부해요.",
            "en": "Sundays I go to school for Chinese.",
            "jp": "日曜は学校で中国語を勉強します。"
          }
        },
        {
          "speaker": "李明",
          "text": "你想家吗？",
          "pinyin": "Nǐ xiǎng jiā ma?",
          "translation": {
            "kr": "가족 보고 싶어요?",
            "en": "Do you miss home?",
            "jp": "ご家族が恋しい？"
          }
        },
        {
          "speaker": "安娜",
          "text": "想，我很爱爸爸妈妈。",
          "pinyin": "Xiǎng, wǒ hěn ài bàba māma.",
          "translation": {
            "kr": "보고 싶어요, 부모님 정말 사랑해요.",
            "en": "Yes—I love my parents.",
            "jp": "ええ、両親のことが大好きです。"
          }
        },
        {
          "speaker": "李明",
          "text": "你不回国看爸爸妈妈吗？",
          "pinyin": "Nǐ bù huí guó kàn bàba māma ma?",
          "translation": {
            "kr": "본국에 안 가고 부모님 안 뵈러 가요?",
            "en": "Won’t you go home to see them?",
            "jp": "ご両親に会いに帰りませんか。"
          }
        },
        {
          "speaker": "安娜",
          "text": "明年爸爸妈妈来中国看我。",
          "pinyin": "Míngnián bàba māma lái Zhōngguó kàn wǒ.",
          "translation": {
            "kr": "내년에 부모님이 중국으로 오셔요.",
            "en": "Next year they’ll come to China to see me.",
            "jp": "来年、両親が中国に会いに来ます。"
          }
        }
      ]
    },
    {
      "title": {
        "zh": "会话二｜工作情况",
