  },
  "summary": {
    "zh": "学习用「做什么」询问课余活动，区分「听」与「听见」，用「只」表限制，用「好听、好玩儿」评价。",
    "kr": "「做什么」「听/听见」「只」「好听·好玩儿」.",
    "en": "做什么; 听/听见; 只; 好听/好玩儿.",
    "jp": "「做什么」「听」「听见」「只」「好听」「好玩儿」。"
  },
  "scene": {
    "id": "hsk30_l18_scene",
    "title": {
      "zh": "课余与爱好",
      "kr": "방과·취미",
      "en": "After school & hobbies",
      "jp": "放課後と趣味"
    },
    "summary": {
      "zh": "会话一：下课听歌、游戏、弟弟找朋友；会话二：只喜欢听歌、歌好听；会话三：听见唱歌、妹妹唱得好听。",
      "kr": "회화1 노래·게임 → 회화2 취향 → 회화3 들림·칭찬.",
      "en": "Music & games · taste · hearing & praise.",
      "jp": "音楽とゲーム／趣味／聞こえるとほめる。"
    }
  },
  "objectives": [
    {
      "zh": "能用「下课后你做什么？」「我听歌」谈论课余活动",
      "pinyin": "xià kè · zuò shénme",
      "kr": "「做什么」로 방과 후 활동을 묻고 말한다.",
      "en": "Ask and say what you do after class.",
      "jp": "「做什么」で放課後のことを言う。"
    },
    {
      "zh": "能区分「听」表主动聆听与「听见」表感知到声音",
      "pinyin": "tīng · tīngjiàn",
      "kr": "「听」과 「听见」를 가른다.",
      "en": "Tell 听 from 听见.",
      "jp": "「听」と「听见」の違い。"
    }
  ],
  "vocab": [],
  "dialogue": [],
  "dialogueCards": [
    {
      "title": {
        "zh": "会话一｜课后活动",
        "kr": "회화 1｜방과 후",
        "en": "Dialogue 1 | After class",
        "jp": "会話1｜放課後"
      },
      "summary": {
        "zh": "问下课后做什么，听歌、玩游戏，弟弟去找小朋友。",
        "kr": "노래·게임·동생은 친구.",
        "en": "Music, games, little brother off to friends.",
        "jp": "音楽、ゲーム、弟は友だち。"
      },
      "lines": [
        {
          "speaker": "李明",
          "text": "下课后你做什么？",
          "pinyin": "Xià kè hòu nǐ zuò shénme?",
          "translation": {
            "kr": "수업 끝나면 뭐 해?",
            "en": "What do you do after class?",
            "jp": "授業のあと何する？"
          }
        },
        {
          "speaker": "汤姆",
          "text": "我听歌，也玩电脑游戏。",
          "pinyin": "Wǒ tīng gē, yě wán diànnǎo yóuxì.",
          "translation": {
            "kr": "노래 듣고 컴퓨터 게임도 해요.",
            "en": "I listen to music and play computer games.",
            "jp": "音楽を聴いて、パソコンゲームもします。"
          }
        },
        {
          "speaker": "李明",
          "text": "游戏好玩儿吗？",
          "pinyin": "Yóuxì hǎowánr ma?",
          "translation": {
            "kr": "게임 재밌어?",
            "en": "Are the games fun?",
            "jp": "ゲームは楽しい？"
          }
        },
        {
          "speaker": "汤姆",
          "text": "好玩儿。",
          "pinyin": "Hǎowánr.",
          "translation": {
            "kr": "재밌어요.",
            "en": "Yeah, fun.",
            "jp": "楽しい。"
          }
        },
        {
          "speaker": "李明",
          "text": "你弟弟呢？",
          "pinyin": "Nǐ dìdi ne?",
          "translation": {
            "kr": "남동생은?",
            "en": "What about your brother?",
            "jp": "弟は？"
          }
        },
        {
          "speaker": "汤姆",
          "text": "他去找小朋友玩了。",
          "pinyin": "Tā qù zhǎo xiǎopéngyou wán le.",
          "translation": {
            "kr": "친구 찾아 놀러 갔어요.",
            "en": "He went to play with friends.",
            "jp": "友だちを探しに遊びに行った。"
          }
        }
      ]
    },
    {
      "title": {
        "zh": "会话二｜说爱好",
        "kr": "회화 2｜취향",
        "en": "Dialogue 2 | Preferences",
        "jp": "会話2｜好み"
      },
      "summary": {
        "zh": "喜欢唱歌还是只喜欢听歌，这首歌好不好听。",
        "kr": "노래 부르기 vs 듣기·곡 평가.",
        "en": "Singing vs listening—how’s the song.",
        "jp": "歌うか聴くか、曲の評価。"
      },
      "lines": [
        {
          "speaker": "王美",
          "text": "你喜欢唱歌吗？",
          "pinyin": "Nǐ xǐhuan chàng gē ma?",
          "translation": {
            "kr": "노래 부르는 거 좋아해?",
            "en": "Do you like singing?",
            "jp": "歌うのは好き？"
          }
        },
        {
          "speaker": "汤姆",
          "text": "我只喜欢听歌。",
          "pinyin": "Wǒ zhǐ xǐhuan tīng gē.",
          "translation": {
            "kr": "듣는 것만 좋아해요.",
            "en": "I only like listening.",
            "jp": "聴くのが好きです。"
          }
        },
        {
          "speaker": "王美",
          "text": "这首歌怎么样？",
          "pinyin": "Zhè shǒu gē zěnmeyàng?",
          "translation": {
            "kr": "이 노래 어때?",
            "en": "How’s this song?",
            "jp": "この歌どう？"
          }
        },
        {
          "speaker": "汤姆",
          "text": "很好听。",
          "pinyin": "Hěn hǎotīng.",
          "translation": {
            "kr": "아주 좋아요.",
            "en": "Sounds great.",
            "jp": "とてもいい。"
          }
        }
      ]
    },
    {
      "title": {
        "zh": "会话三｜说别人爱好",
        "kr": "회화 3｜남의 취미",
        "en": "Dialogue 3 | Someone else’s hobby",
        "jp": "会話3｜ほかの人"
      },
      "summary": {
        "zh": "有没有听见唱歌、妹妹在唱、唱得好听。",
        "kr": "노래 소리·여동생·칭찬.",
        "en": "Hear singing—sister—praising.",
        "jp": "歌声・妹・ほめる。"
      },
      "lines": [
        {
          "speaker": "王美",
          "text": "你听见有人在唱歌吗？",
          "pinyin": "Nǐ tīngjiàn yǒu rén zài chàng gē ma?",
          "translation": {
            "kr": "누가 노래하는 소리 들려요?",
            "en": "Do you hear someone singing?",
            "jp": "だれか歌ってるの聞こえる？"
          }
        },
        {
          "speaker": "汤姆",
          "text": "是的，我妹妹在唱歌呢。",
          "pinyin": "Shì de, wǒ mèimei zài chàng gē ne.",
          "translation": {
            "kr": "네, 여동생이 노래해요.",
            "en": "Yes—my sister’s singing.",
            "jp": "ええ、妹が歌ってます。"
          }
        },
        {
          "speaker": "王美",
          "text": "你妹妹唱歌真好听。",
          "pinyin": "Nǐ mèimei chàng gē zhēn hǎotīng.",
          "translation": {
            "kr": "여동생 노래 정말 잘하네요.",
            "en": "She sings really well.",
            "jp": "妹さん、歌が上手ですね。"
          }
        },
        {
          "speaker": "汤姆",
          "text": "是的，她很喜欢唱歌。",
          "pinyin": "Shì de, tā hěn xǐhuan chàng gē.",
          "translation": {
            "kr": "네, 노래 부르는 걸 좋아해요.",
            "en": "Yeah—she loves to sing.",
            "jp": "ええ、歌うのが大好きなんです。"
          }
        }
      ]
    }
  ],
  "grammar": [
    {
      "pattern": "做什么",
      "pinyin": "zuò shénme",
      "hint": {
        "zh": "询问活动",
        "kr": "무엇을 하다",
        "en": "what you do",
        "jp": "何をする"
      },
      "explanation": {
        "zh": "疑问代词「什么」与动词「做」搭配，可询问进行的活动或安排，如「你做什么？」「下课后你做什么？」。\n\n「做什么」\nzuò shénme",
        "kr": "「做什么」로 하는 일을 묻습니다.",
        "en": "做什么 asks what activity.",
        "jp": "「做什么」は何をするか。"
      },
      "examples": [
        {
          "zh": "下课后你做什么？",
          "pinyin": "Xià kè hòu nǐ zuò shénme?",
          "translation": {
            "kr": "수업 끝나면 뭐 해?",
            "en": "What do you do after class?",
            "jp": "放課後何する？"
          }
        }
      ]
    },
    {
      "pattern": "只",
      "pinyin": "zhǐ",
      "hint": {
        "zh": "限制范围",
        "kr": "만",
        "en": "only",
        "jp": "だけ"
      },
      "explanation": {
        "zh": "副词「只」用于限制范围，表示除此以外不包括其他，如「我只喜欢听歌」。\n\n「只」\nzhǐ",
        "kr": "「只」는 한정.",
        "en": "只 = only / nothing but.",
        "jp": "「只」はだけ。"
      },
      "examples": [
        {
          "zh": "我只喜欢听歌。",
          "pinyin": "Wǒ zhǐ xǐhuan tīng gē.",
          "translation": {
            "kr": "듣는 것만 좋아해요.",
            "en": "I only like listening.",
            "jp": "聴くのだけ好き。"
          }
        }
      ]
    },
    {
      "pattern": "听 / 听见",
      "pinyin": "tīng / tīngjiàn",
      "hint": {
        "zh": "听辨",
        "kr": "듣기·들림",
        "en": "listen / hear",
        "jp": "聞く・聞こえる"
      },
      "explanation": {
        "zh": "「听」强调主动聆听；「听见」强调感知到声音的结果，如「听见有人在唱歌」。\n\n「听见」\ntīngjiàn",
        "kr": "「听」는 듣기,「听见」는 들리다.",
        "en": "听 = listen; 听见 = hear (notice).",
        "jp": "「听」は聞く、「听见」は聞こえる。"
      },
      "examples": [
        {
          "zh": "我听歌。",
          "pinyin": "Wǒ tīng gē.",
          "translation": {
            "kr": "노래 들어요.",
            "en": "I listen to songs.",
            "jp": "歌を聴きます。"
          }
        },
        {
          "zh": "你听见有人在唱歌吗？",
          "pinyin": "Nǐ tīngjiàn yǒu rén zài chàng gē ma?",
          "translation": {
            "kr": "누가 노래하는 소리 들려요?",
            "en": "Do you hear someone singing?",
            "jp": "歌ってるの聞こえる？"
          }
        }
      ]
    },
    {
      "pattern": "好听 / 好玩儿",
      "pinyin": "hǎotīng / hǎowánr",
      "hint": {
        "zh": "评价",
        "kr": "평가",
        "en": "sounds good / fun",
        "jp": "耳心地・楽しさ"
      },
      "explanation": {
        "zh": "形容词「好听」多用于评价声音、歌曲；「好玩儿」多用于评价游戏、活动是否有趣。\n\n「好玩儿」\nhǎowánr",
        "kr": "「好听」는 소리,「好玩儿」는 재미.",
        "en": "好听 = pleasant to hear; 好玩儿 = fun.",
        "jp": "「好听」は音、「好玩儿」はおもしろさ。"
      },
      "examples": [
        {
          "zh": "很好听。",
          "pinyin": "Hěn hǎotīng.",
          "translation": {
